@inherits LayoutComponentBase

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <AuthorizeView>
            <Authorized>
                <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit"
                               Edge="Edge.Start" OnClick="ToggleDrawer" />
            </Authorized>
        </AuthorizeView>
        <MudText Typo="Typo.h6" Class="ml-3">
            @(_currentBoardName ?? "NivoTask")
        </MudText>
        <MudSpacer />
        @if (_currentBoardId > 0)
        {
            <MudIconButton Icon="@Icons.Material.Filled.Settings" Color="Color.Inherit"
                           OnClick="OnSettingsClicked" />
        }
        <AuthorizeView>
            <Authorized>
                <MudButton Variant="Variant.Text" Color="Color.Inherit" OnClick="HandleLogout">Logout</MudButton>
            </Authorized>
        </AuthorizeView>
    </MudAppBar>
    <AuthorizeView>
        <Authorized>
            <MudDrawer @bind-Open="_drawerOpen"
                       ClipMode="DrawerClipMode.Always"
                       Variant="DrawerVariant.Mini"
                       MiniWidth="56px"
                       Width="260px"
                       Elevation="2">
                <BoardSidebar IsExpanded="_drawerOpen"
                              ActiveBoardId="_currentBoardId"
                              OnBoardSelected="HandleBoardSelected" />
            </MudDrawer>
        </Authorized>
    </AuthorizeView>
    <MudMainContent Class="pa-4">
        <CascadingValue Value="this" IsFixed="true">
            @Body
        </CascadingValue>
    </MudMainContent>
</MudLayout>

@code {
    [Inject] private IAccountManagement AccountManagement { get; set; } = null!;
    [Inject] private NavigationManager Navigation { get; set; } = null!;
    [Inject] private BoardService BoardService { get; set; } = null!;
    [Inject] private IDialogService DialogService { get; set; } = null!;

    private bool _drawerOpen = true;
    private string? _currentBoardName;
    private int _currentBoardId;

    public void SetBoardContext(string boardName, int boardId)
    {
        _currentBoardName = boardName;
        _currentBoardId = boardId;
        StateHasChanged();
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private void HandleBoardSelected(int boardId)
    {
        Navigation.NavigateTo($"/boards/{boardId}");
    }

    private async Task OnSettingsClicked()
    {
        if (_currentBoardId <= 0) return;

        // Fetch current board data for the dialog
        var board = await BoardService.GetBoardAsync(_currentBoardId);
        if (board is null) return;

        // Build column edit models with task counts from board tasks
        var tasks = await BoardService.GetBoardTasksAsync(_currentBoardId);
        var columnModels = board.Columns.Select(c => new BoardSettingsDialog.ColumnEditModel
        {
            Id = c.Id,
            Name = c.Name,
            IsDone = c.IsDone,
            TaskCount = tasks.Count(t => t.ColumnIdentifier == c.Id.ToString()),
            IsNew = false
        }).ToList();

        var parameters = new DialogParameters<BoardSettingsDialog>
        {
            { x => x.BoardId, board.Id },
            { x => x.BoardName, board.Name },
            { x => x.BoardColor, board.Color },
            { x => x.BoardIcon, board.Icon },
            { x => x.Columns, columnModels }
        };

        var dialog = await DialogService.ShowAsync<BoardSettingsDialog>("Board Settings",
            parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            if (result.Data is string s && s == "deleted")
            {
                // Board was deleted, navigate to board list
                _currentBoardName = null;
                _currentBoardId = 0;
                StateHasChanged();
                return;
            }

            // Board was updated, reload current page
            Navigation.NavigateTo($"/boards/{_currentBoardId}", forceLoad: true);
        }
    }

    private async Task HandleLogout()
    {
        await AccountManagement.LogoutAsync();
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}
