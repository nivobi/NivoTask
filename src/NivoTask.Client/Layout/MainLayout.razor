@inherits LayoutComponentBase
@implements IDisposable
@inject IJSRuntime JS

<MudThemeProvider Theme="_theme" @bind-IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Class="app-bar-glass">
        <AuthorizeView>
            <Authorized>
                <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit"
                               Edge="Edge.Start" OnClick="ToggleDrawer" />
            </Authorized>
        </AuthorizeView>
        <MudText Typo="Typo.subtitle1" Class="ml-3" Style="font-weight: 600; letter-spacing: -0.01em;">
            @(_currentBoardName ?? "NivoTask")
        </MudText>
        <MudSpacer />
        <TimerChip OnNavigateToTask="OpenDetailPanel" OnTimerStopped="HandleTimerStopped"
                   OnTimerStoppedEntry="HandleTimerStoppedEntry" />
        @if (_currentBoardId > 0)
        {
            <MudIconButton Icon="@Icons.Material.Filled.Settings" Color="Color.Default" Size="Size.Small"
                           OnClick="OnSettingsClicked" Style="opacity: 0.6;" />
        }
        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Outlined.LightMode : Icons.Material.Outlined.DarkMode)"
                       Color="Color.Default" Size="Size.Small"
                       OnClick="ToggleDarkMode"
                       Style="opacity: 0.6;" />
        <AuthorizeView>
            <Authorized>
                <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small"
                           OnClick="HandleLogout" Style="text-transform: none; font-weight: 500; opacity: 0.6;">
                    Logout
                </MudButton>
            </Authorized>
        </AuthorizeView>
    </MudAppBar>
    <AuthorizeView>
        <Authorized>
            <MudDrawer @bind-Open="_drawerOpen"
                       ClipMode="DrawerClipMode.Always"
                       Variant="DrawerVariant.Mini"
                       MiniWidth="56px"
                       Width="260px"
                       Elevation="0"
                       Class="drawer-border">
                <BoardSidebar IsExpanded="_drawerOpen"
                              ActiveBoardId="_currentBoardId"
                              OnBoardSelected="HandleBoardSelected" />
            </MudDrawer>
        </Authorized>
    </AuthorizeView>
    <MudMainContent Class="pa-5" Style="background: var(--mud-palette-background); padding-top: 76px !important;">
        <CascadingValue Value="this" IsFixed="true">
            @Body
        </CascadingValue>
    </MudMainContent>
    <MudDrawer @bind-Open="_detailPanelOpen"
               Anchor="Anchor.End"
               Variant="DrawerVariant.Temporary"
               Width="480px"
               Elevation="0"
               ClipMode="DrawerClipMode.Always"
               Class="detail-panel-shadow">
        @if (_selectedTaskId > 0)
        {
            <TaskDetailPanel TaskId="_selectedTaskId" BoardId="_currentBoardId" OnClose="CloseDetailPanel" OnDeleted="HandleTaskDeleted" OnTaskUpdated="HandleTaskUpdated" />
        }
    </MudDrawer>
</MudLayout>

<SearchPalette IsOpen="_searchOpen"
               OnClose="() => { _searchOpen = false; StateHasChanged(); }"
               OnPick="HandleSearchPick" />

@if (_showShortcutsHelp)
{
    <div class="shortcuts-overlay" @onclick="() => _showShortcutsHelp = false">
        <div class="shortcuts-panel" @onclick:stopPropagation="true">
            <div class="d-flex justify-space-between align-center mb-4">
                <MudText Typo="Typo.h6">Keyboard Shortcuts</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                               OnClick="() => _showShortcutsHelp = false" />
            </div>
            <div class="shortcuts-grid">
                <div class="shortcut-row"><kbd>?</kbd><span>Show this help</span></div>
                <div class="shortcut-row"><kbd>Esc</kbd><span>Close panel / dialog</span></div>
                <div class="shortcut-row"><kbd>Ctrl</kbd><kbd>K</kbd><span>Search tasks across boards</span></div>
                <div class="shortcut-row"><kbd>n</kbd><span>New task in first column</span></div>
                <div class="shortcut-row"><kbd>f</kbd><span>Focus board search</span></div>
            </div>
        </div>
    </div>
}

<style>
    .shortcuts-overlay {
        position: fixed; inset: 0; z-index: 9999;
        background: rgba(0,0,0,0.4); backdrop-filter: blur(4px);
        display: flex; align-items: center; justify-content: center;
        animation: fadeScaleIn 0.2s var(--ease-decelerate);
    }
    .shortcuts-panel {
        background: var(--mud-palette-surface); border-radius: 16px;
        padding: 28px; min-width: 320px; max-width: 400px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.12);
    }
    .shortcuts-grid { display: flex; flex-direction: column; gap: 8px; }
    .shortcut-row { display: flex; align-items: center; gap: 12px; }
    .shortcut-row kbd {
        background: var(--mud-palette-background-gray); border-radius: 6px;
        padding: 4px 10px; font-size: 0.75rem; font-weight: 600;
        min-width: 40px; text-align: center; font-family: inherit;
    }
    .shortcut-row span { font-size: 0.8125rem; opacity: 0.7; }
    .app-bar-glass {
        border-bottom: 1px solid var(--mud-palette-divider);
        background: var(--mud-palette-appbar-background) !important;
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
    }
    .drawer-border {
        border-right: 1px solid var(--mud-palette-divider);
    }
    .detail-panel-shadow {
        box-shadow: -8px 0 32px var(--mud-palette-overlay-dark) !important;
    }
</style>

@code {
    [Inject] private IAccountManagement AccountManagement { get; set; } = null!;
    [Inject] private NavigationManager Navigation { get; set; } = null!;
    [Inject] private BoardService BoardService { get; set; } = null!;
    [Inject] private TaskService TaskService { get; set; } = null!;
    [Inject] private IDialogService DialogService { get; set; } = null!;
    [Inject] private TimerStateService TimerState { get; set; } = null!;
    [Inject] private TimeEntryService TimeEntryService { get; set; } = null!;
    [Inject] private ThemeService _themeService { get; set; } = null!;
    [Inject] private ISnackbar Snackbar { get; set; } = null!;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#1d1d1f",
            PrimaryContrastText = "#ffffff",
            Secondary = "#007AFF",
            Background = "#f5f5f7",
            Surface = "#ffffff",
            AppbarBackground = "rgba(255,255,255,0.82)",
            AppbarText = "#1d1d1f",
            DrawerBackground = "#ffffff",
            TextPrimary = "#1d1d1f",
            TextSecondary = "rgba(0,0,0,0.45)",
            ActionDefault = "rgba(0,0,0,0.48)",
            ActionDisabled = "rgba(0,0,0,0.22)",
            Divider = "rgba(0,0,0,0.04)",
            BackgroundGray = "#f0f0f2",
            OverlayDark = "rgba(0,0,0,0.08)",
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#f5f5f7",
            PrimaryContrastText = "#000000",
            Secondary = "#0A84FF",
            Background = "#000000",
            Surface = "#1c1c1e",
            AppbarBackground = "rgba(0,0,0,0.82)",
            AppbarText = "#f5f5f7",
            DrawerBackground = "#1c1c1e",
            TextPrimary = "rgba(255,255,255,0.92)",
            TextSecondary = "rgba(255,255,255,0.55)",
            ActionDefault = "rgba(255,255,255,0.55)",
            ActionDisabled = "rgba(255,255,255,0.25)",
            Divider = "rgba(255,255,255,0.06)",
            Black = "#2c2c2e",
            BackgroundGray = "#2c2c2e",
            OverlayDark = "rgba(0,0,0,0.35)",
        },
        Typography = new Typography
        {
            Default = new DefaultTypography
            {
                FontFamily = new[] { "-apple-system", "BlinkMacSystemFont", "SF Pro Text", "SF Pro Display", "Inter", "Segoe UI", "Roboto", "Helvetica Neue", "Arial", "sans-serif" },
                LetterSpacing = "-0.011em",
            },
            H5 = new H5Typography { FontWeight = "600", FontSize = "1.5rem", LetterSpacing = "-0.022em", LineHeight = "1.2" },
            H6 = new H6Typography { FontWeight = "600", FontSize = "1.125rem", LetterSpacing = "-0.017em", LineHeight = "1.3" },
            Subtitle1 = new Subtitle1Typography { FontWeight = "600", FontSize = "1rem", LetterSpacing = "-0.014em" },
            Body1 = new Body1Typography { FontSize = "0.9375rem", LetterSpacing = "-0.01em", LineHeight = "1.53" },
            Body2 = new Body2Typography { FontSize = "0.8125rem", LetterSpacing = "-0.006em", LineHeight = "1.5" },
            Button = new ButtonTypography { FontWeight = "500", FontSize = "0.8125rem", TextTransform = "none", LetterSpacing = "-0.006em" },
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "12px",
            AppbarHeight = "56px",
        }
    };

    private bool _isDarkMode;
    private bool _drawerOpen = true;
    private string? _currentBoardName;
    private int _currentBoardId;
    private bool _detailPanelOpen;
    private int _selectedTaskId;
    private bool _timerLoaded;
    private bool _showShortcutsHelp;
    private bool _searchOpen;
    private DotNetObjectReference<MainLayout>? _keyboardRef;
    private DotNetObjectReference<MainLayout>? _idleRef;
    private DateTime _idleCooldownUntil = DateTime.MinValue;
    private bool _idlePromptOpen;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Initialize theme from localStorage
            await _themeService.InitializeAsync();
            _isDarkMode = _themeService.IsDarkMode;
            _themeService.OnThemeChanged += HandleThemeChanged;
            StateHasChanged();

            // Init keyboard shortcuts
            _keyboardRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("NivoTaskKeyboard.init", _keyboardRef);

            // Init idle detector (5 min threshold)
            _idleRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("NivoTaskIdle.init", _idleRef, 300);

            if (!_timerLoaded)
            {
                _timerLoaded = true;
                try
                {
                    var active = await TimeEntryService.GetActiveTimerAsync();
                    if (active is not null)
                    {
                        TimerState.SetActive(active.TaskId, active.TaskTitle, active.BoardId, active.BoardName, active.EntryId, active.StartTime);
                        StateHasChanged();
                    }
                }
                catch { }
            }
        }
    }

    public void SetBoardContext(string boardName, int boardId)
    {
        _currentBoardName = boardName;
        _currentBoardId = boardId;
        StateHasChanged();
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private async Task ToggleDarkMode()
    {
        await _themeService.ToggleAsync();
        _isDarkMode = _themeService.IsDarkMode;
    }

    private async void HandleThemeChanged()
    {
        _isDarkMode = _themeService.IsDarkMode;
        await InvokeAsync(StateHasChanged);
    }

    private void HandleBoardSelected(int boardId)
    {
        Navigation.NavigateTo($"/boards/{boardId}");
    }

    private async Task OnSettingsClicked()
    {
        if (_currentBoardId <= 0) return;

        // Fetch current board data for the dialog
        var board = await BoardService.GetBoardAsync(_currentBoardId);
        if (board is null) return;

        // Build column edit models with task counts from board tasks
        var tasks = await BoardService.GetBoardTasksAsync(_currentBoardId);
        var columnModels = board.Columns.Select(c => new BoardSettingsDialog.ColumnEditModel
        {
            Id = c.Id,
            Name = c.Name,
            IsDone = c.IsDone,
            TaskCount = tasks.Count(t => t.ColumnIdentifier == c.Id.ToString()),
            IsNew = false
        }).ToList();

        var parameters = new DialogParameters<BoardSettingsDialog>
        {
            { x => x.BoardId, board.Id },
            { x => x.BoardName, board.Name },
            { x => x.BoardColor, board.Color },
            { x => x.BoardIcon, board.Icon },
            { x => x.BoardBackgroundType, board.BackgroundType },
            { x => x.BoardBackgroundValue, board.BackgroundValue },
            { x => x.Columns, columnModels }
        };

        var dialog = await DialogService.ShowAsync<BoardSettingsDialog>("Board Settings",
            parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            if (result.Data is string s && s == "deleted")
            {
                // Board was deleted, navigate to board list
                _currentBoardName = null;
                _currentBoardId = 0;
                StateHasChanged();
                return;
            }

            // Board was updated, reload current page
            Navigation.NavigateTo($"/boards/{_currentBoardId}", forceLoad: true);
        }
    }

    private async Task HandleLogout()
    {
        await AccountManagement.LogoutAsync();
        Navigation.NavigateTo("/login", forceLoad: true);
    }

    public void OpenDetailPanel(int taskId)
    {
        _selectedTaskId = taskId;
        _detailPanelOpen = true;
        StateHasChanged();
    }

    public void CloseDetailPanel()
    {
        _detailPanelOpen = false;
        _selectedTaskId = 0;
        StateHasChanged();
    }

    // Event for board to subscribe to when task metadata changes in detail panel
    public event Action<int>? OnTaskMetadataChanged;

    // Event for pages to subscribe to global keyboard shortcuts ("n", "f", etc.)
    public event Action<string>? OnGlobalShortcut;

    private void HandleTaskUpdated(int taskId)
    {
        OnTaskMetadataChanged?.Invoke(taskId);
    }

    private async Task HandleTimerStopped(int? subtaskId)
    {
        StateHasChanged();
        if (!subtaskId.HasValue) return;
        // Find parent task to refresh board card
        try
        {
            var detail = await TaskService.GetTaskDetailAsync(subtaskId.Value);
            if (detail?.ParentTaskId is not null)
                OnTaskMetadataChanged?.Invoke(detail.ParentTaskId.Value);
        }
        catch { }
    }

    private void HandleTimerStoppedEntry(NivoTask.Shared.Dtos.TimeEntries.TimeEntryResponse? entry)
    {
        if (entry is null || entry.DurationSeconds <= 0) return;
        Snackbar.Add(
            $"Stopped: {FormatHm(entry.DurationSeconds)}. Adjust?",
            Severity.Normal,
            cfg =>
            {
                cfg.Action = "Adjust";
                cfg.ActionColor = Color.Secondary;
                cfg.OnClick = async snackbar =>
                {
                    await OpenQuickEditDialog(entry);
                };
                cfg.VisibleStateDuration = 8000;
            });
    }

    private async Task OpenQuickEditDialog(NivoTask.Shared.Dtos.TimeEntries.TimeEntryResponse entry)
    {
        var parameters = new DialogParameters<TimeEntryQuickEditDialog>
        {
            { x => x.EntryId, entry.Id },
            { x => x.InitialDurationSeconds, entry.DurationSeconds },
            { x => x.InitialNotes, entry.Notes }
        };
        var dialog = await DialogService.ShowAsync<TimeEntryQuickEditDialog>("",
            parameters, new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, NoHeader = true });
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            Snackbar.Add("Entry updated.", Severity.Success);
        }
    }

    private static string FormatHm(int seconds)
    {
        var ts = TimeSpan.FromSeconds(seconds);
        var h = (int)ts.TotalHours;
        var m = ts.Minutes;
        if (h == 0 && m == 0) return $"{seconds}s";
        if (h == 0) return $"{m}m";
        if (m == 0) return $"{h}h";
        return $"{h}h {m}m";
    }

    private void HandleTaskDeleted(int taskId)
    {
        CloseDetailPanel();
        // Force board page to reload by navigating to same URL
        Navigation.NavigateTo(Navigation.Uri, forceLoad: true);
    }

    [JSInvokable]
    public async Task OnKeyPressed(string key, bool ctrlOrMeta, bool shift)
    {
        switch (key)
        {
            case "Escape":
                if (_showShortcutsHelp) { _showShortcutsHelp = false; StateHasChanged(); }
                else if (_detailPanelOpen) CloseDetailPanel();
                break;
            case "?":
                if (shift) { _showShortcutsHelp = !_showShortcutsHelp; StateHasChanged(); }
                break;
            case "k" when ctrlOrMeta:
                _searchOpen = true;
                StateHasChanged();
                break;
            case "n":
                if (!ctrlOrMeta && !shift) OnGlobalShortcut?.Invoke("new-task");
                break;
            case "f":
                if (!ctrlOrMeta && !shift) OnGlobalShortcut?.Invoke("focus-filter");
                break;
        }
        await Task.CompletedTask;
    }

    [JSInvokable]
    public async Task OnIdle(int idleSeconds)
    {
        if (!TimerState.IsRunning) return;
        if (_idlePromptOpen) return;
        if (DateTime.UtcNow < _idleCooldownUntil) return;

        _idlePromptOpen = true;
        try
        {
            var taskTitle = TimerState.ActiveTaskTitle ?? TimerState.ActiveBoardName;
            var parameters = new DialogParameters<IdlePromptDialog>
            {
                { x => x.IdleSeconds, idleSeconds },
                { x => x.TaskTitle, taskTitle }
            };
            var dialog = await DialogService.ShowAsync<IdlePromptDialog>("",
                parameters, new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, NoHeader = true, BackdropClick = false });
            var result = await dialog.Result;

            try { await JS.InvokeVoidAsync("NivoTaskIdle.bump"); } catch { }

            if (result is null || result.Canceled || result.Data is not IdlePromptDialog.IdleAction action)
            {
                _idleCooldownUntil = DateTime.UtcNow.AddMinutes(5);
                return;
            }

            switch (action)
            {
                case IdlePromptDialog.IdleAction.Keep:
                    _idleCooldownUntil = DateTime.UtcNow.AddMinutes(5);
                    break;
                case IdlePromptDialog.IdleAction.Discard:
                    await DiscardActiveTimer();
                    break;
                case IdlePromptDialog.IdleAction.Trim:
                    await TrimActiveTimer(idleSeconds);
                    break;
            }
        }
        finally
        {
            _idlePromptOpen = false;
        }
    }

    private async Task DiscardActiveTimer()
    {
        var entryId = TimerState.ActiveEntryId;
        var taskId = TimerState.ActiveTaskId;
        var boardId = TimerState.ActiveBoardId;
        try
        {
            if (taskId.HasValue)
                await TimeEntryService.StopTimerAsync(taskId.Value);
            else if (boardId.HasValue)
                await TimeEntryService.StopBoardTimerAsync(boardId.Value);
            TimerState.Clear();
            if (entryId.HasValue)
            {
                try { await TimeEntryService.DeleteTimeEntryAsync(entryId.Value); } catch { }
            }
        }
        catch { }
        StateHasChanged();
    }

    private async Task TrimActiveTimer(int idleSeconds)
    {
        var taskId = TimerState.ActiveTaskId;
        var boardId = TimerState.ActiveBoardId;
        var entryId = TimerState.ActiveEntryId;
        var elapsed = TimerState.ElapsedSeconds;
        var keptSeconds = Math.Max(0, elapsed - idleSeconds);

        try
        {
            if (taskId.HasValue)
                await TimeEntryService.StopTimerAsync(taskId.Value);
            else if (boardId.HasValue)
                await TimeEntryService.StopBoardTimerAsync(boardId.Value);
            TimerState.Clear();

            if (entryId.HasValue)
            {
                try { await TimeEntryService.DeleteTimeEntryAsync(entryId.Value); } catch { }
            }

            if (keptSeconds >= 60)
            {
                var keptMinutes = keptSeconds / 60;
                if (taskId.HasValue)
                {
                    await TimeEntryService.CreateManualEntryAsync(taskId.Value,
                        new NivoTask.Shared.Dtos.TimeEntries.CreateTimeEntryRequest
                        {
                            DurationMinutes = keptMinutes
                        });
                }
                else if (boardId.HasValue)
                {
                    await TimeEntryService.CreateBoardManualEntryAsync(boardId.Value,
                        new NivoTask.Shared.Dtos.TimeEntries.CreateBoardTimeEntryRequest
                        {
                            DurationMinutes = keptMinutes
                        });
                }
            }
        }
        catch { }
        StateHasChanged();
    }

    private void HandleSearchPick(NivoTask.Shared.Dtos.Tasks.TaskSearchResult r)
    {
        var openId = r.ParentTaskId ?? r.TaskId;
        if (_currentBoardId != r.BoardId)
        {
            _searchOpen = false;
            Navigation.NavigateTo($"/boards/{r.BoardId}");
        }
        OpenDetailPanel(openId);
    }

    public void Dispose()
    {
        _themeService.OnThemeChanged -= HandleThemeChanged;
        try { _ = JS.InvokeVoidAsync("NivoTaskKeyboard.dispose"); } catch { }
        try { _ = JS.InvokeVoidAsync("NivoTaskIdle.dispose"); } catch { }
        _keyboardRef?.Dispose();
        _idleRef?.Dispose();
    }
}
