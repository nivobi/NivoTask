@code {
    private bool _loading = true;
    private List<BoardSummaryResponse>? _boards;
    private List<BoardSummaryResponse>? _archivedBoards;
    private bool _showArchived;
    private TimeSummaryResponse? _summary;
    private List<DailyTotalResponse>? _daily;
    private List<DailyTotalResponse>? _heatmap;
    private List<TopTaskResponse>? _topTasks;
    private string _greeting = "Hello";
    private string _userName = string.Empty;
    private string _dateLabel = string.Empty;

    private int _quickBoardId;
    private int? _quickTaskId;
    private string? _quickNotes;
    private bool _quickStarting;
    private List<BoardTaskItem>? _quickBoardTasks;

    private int _dailyGoalMinutes;
    private int _weeklyGoalMinutes;
    private bool _editingDailyGoal;
    private bool _editingWeeklyGoal;
    private int _dailyGoalDraft;
    private int _weeklyGoalDraft;

    private bool _exportDialogOpen;
    private DateRange _exportRange = new(DateTime.Today.AddDays(-29), DateTime.Today);

    private void OpenExportDialog()
    {
        _exportRange = new DateRange(DateTime.Today.AddDays(-29), DateTime.Today);
        _exportDialogOpen = true;
    }

    private void DoExport()
    {
        if (_exportRange?.Start is null || _exportRange.End is null)
        {
            Snackbar.Add("Pick a start and end date.", Severity.Warning);
            return;
        }
        var from = _exportRange.Start.Value.ToString("yyyy-MM-dd");
        var to = _exportRange.End.Value.ToString("yyyy-MM-dd");
        _exportDialogOpen = false;
        Navigation.NavigateTo($"api/time-entries/export?from={from}&to={to}", forceLoad: true);
    }

    protected override async Task OnInitializedAsync()
    {
        TimerState.OnTimerChanged += HandleTimerChanged;

        var now = DateTime.Now;
        _greeting = now.Hour < 5 ? "Good night"
                  : now.Hour < 12 ? "Good morning"
                  : now.Hour < 18 ? "Good afternoon"
                  : "Good evening";
        _dateLabel = now.ToString("dddd, MMMM d");

        try
        {
            var auth = await AuthState.GetAuthenticationStateAsync();
            var name = auth.User.Identity?.Name ?? "";
            _userName = name.Contains('@') ? name.Split('@')[0] : name;
            if (!string.IsNullOrEmpty(_userName))
                _userName = char.ToUpper(_userName[0]) + _userName[1..];
        }
        catch { }

        try
        {
            var boardsTask = BoardService.GetBoardsAsync();
            var archivedTask = BoardService.GetArchivedBoardsAsync();
            var summaryTask = TimeEntryService.GetSummaryAsync();
            var dailyTask = TimeEntryService.GetDailyAsync(7);
            var heatmapTask = TimeEntryService.GetDailyAsync(84);
            var topTasksTask = TimeEntryService.GetTopTasksAsync(7, 5);
            await Task.WhenAll(boardsTask, archivedTask, summaryTask, dailyTask, heatmapTask, topTasksTask);
            _boards = boardsTask.Result;
            _archivedBoards = archivedTask.Result;
            _summary = summaryTask.Result;
            _daily = dailyTask.Result;
            _heatmap = heatmapTask.Result;
            _topTasks = topTasksTask.Result;

            if (_boards.Count > 0)
                _quickBoardId = _boards[0].Id;

            _dailyGoalMinutes = await LocalStorage.GetIntAsync("goal.daily.minutes") ?? 0;
            _weeklyGoalMinutes = await LocalStorage.GetIntAsync("goal.weekly.minutes") ?? 0;
        }
        catch
        {
            _boards ??= [];
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnQuickBoardChanged(int boardId)
    {
        _quickBoardId = boardId;
        _quickTaskId = null;
        _quickBoardTasks = null;
        if (boardId == 0) return;
        try { _quickBoardTasks = await BoardService.GetBoardTasksAsync(boardId); }
        catch { _quickBoardTasks = []; }
    }

    private async Task HandleQuickKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !_quickStarting && _quickBoardId != 0)
            await StartQuickTimer();
    }

    private async Task StartQuickTimer()
    {
        if (_quickBoardId == 0 || _quickStarting) return;
        _quickStarting = true;
        try
        {
            HttpResponseMessage response;
            if (_quickTaskId.HasValue)
            {
                response = await TimeEntryService.StartTimerAsync(_quickTaskId.Value);
            }
            else
            {
                response = await TimeEntryService.StartBoardTimerAsync(_quickBoardId,
                    new StartBoardTimerRequest { Notes = string.IsNullOrWhiteSpace(_quickNotes) ? null : _quickNotes });
            }

            if (response.StatusCode == System.Net.HttpStatusCode.Conflict)
            {
                Snackbar.Add("Timer already running. Stop it first.", Severity.Warning);
                return;
            }
            if (!response.IsSuccessStatusCode)
            {
                Snackbar.Add("Could not start timer.", Severity.Error);
                return;
            }

            var active = await TimeEntryService.GetActiveTimerAsync();
            if (active is not null)
                TimerState.SetActive(active.TaskId, active.TaskTitle, active.BoardId, active.BoardName, active.EntryId, active.StartTime);

            _quickNotes = null;
            _quickTaskId = null;
        }
        catch
        {
            Snackbar.Add("Could not start timer.", Severity.Error);
        }
        finally
        {
            _quickStarting = false;
        }
    }

    private void StartEditDailyGoal()
    {
        _dailyGoalDraft = _dailyGoalMinutes;
        _editingDailyGoal = true;
    }

    private async Task SaveDailyGoal()
    {
        var v = Math.Max(0, Math.Min(1440, _dailyGoalDraft));
        _dailyGoalMinutes = v;
        _editingDailyGoal = false;
        await LocalStorage.SetIntAsync("goal.daily.minutes", v);
    }

    private async Task HandleDailyGoalKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SaveDailyGoal();
        else if (e.Key == "Escape") _editingDailyGoal = false;
    }

    private void StartEditWeeklyGoal()
    {
        _weeklyGoalDraft = _weeklyGoalMinutes;
        _editingWeeklyGoal = true;
    }

    private async Task SaveWeeklyGoal()
    {
        var v = Math.Max(0, Math.Min(10080, _weeklyGoalDraft));
        _weeklyGoalMinutes = v;
        _editingWeeklyGoal = false;
        await LocalStorage.SetIntAsync("goal.weekly.minutes", v);
    }

    private async Task HandleWeeklyGoalKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SaveWeeklyGoal();
        else if (e.Key == "Escape") _editingWeeklyGoal = false;
    }

    private async Task RestoreBoard(int boardId)
    {
        try
        {
            await BoardService.UnarchiveBoardAsync(boardId);
            var moved = _archivedBoards?.FirstOrDefault(b => b.Id == boardId);
            if (moved is not null)
            {
                _archivedBoards!.Remove(moved);
                _boards ??= [];
                _boards.Add(moved);
                _boards = _boards.OrderBy(b => b.Name).ToList();
            }
            Snackbar.Add("Board restored.", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Could not restore board.", Severity.Error);
        }
    }

    private void HandleTimerChanged() => InvokeAsync(StateHasChanged);

    private void OpenActiveTask()
    {
        if (TimerState.ActiveTaskId is not int taskId) return;
        // Navigate to first board where this task lives — fallback open on /boards
        Navigation.NavigateTo("/boards");
    }

    private static string FormatHms(int seconds)
    {
        var ts = TimeSpan.FromSeconds(seconds);
        return $"{(int)ts.TotalHours:D2}:{ts.Minutes:D2}:{ts.Seconds:D2}";
    }

    private static string FormatHm(int seconds)
    {
        var ts = TimeSpan.FromSeconds(seconds);
        var h = (int)ts.TotalHours;
        var m = ts.Minutes;
        if (h == 0 && m == 0) return "0m";
        if (h == 0) return $"{m}m";
        if (m == 0) return $"{h}h";
        return $"{h}h {m}m";
    }

    public void Dispose()
    {
        TimerState.OnTimerChanged -= HandleTimerChanged;
    }
}
