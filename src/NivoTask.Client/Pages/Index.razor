@page "/"
@page "/dashboard"
@attribute [Authorize]
@using NivoTask.Shared.Dtos.TimeEntries
@using NivoTask.Client.Models
@implements IDisposable
@inject BoardService BoardService
@inject TimeEntryService TimeEntryService
@inject TimerStateService TimerState
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthState
@inject ISnackbar Snackbar

<div class="dashboard-root">
    <div class="dashboard-header">
        <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary); font-weight: 500;">
            @_dateLabel
        </MudText>
        <MudText Typo="Typo.h3" Style="font-weight: 600; letter-spacing: -0.03em; margin-top: 4px;">
            @_greeting@(string.IsNullOrEmpty(_userName) ? "" : $", {_userName}")
        </MudText>
    </div>

    @if (TimerState.IsRunning)
    {
        <div class="timer-hero" @onclick="OpenActiveTask">
            <div class="timer-pulse"></div>
            <div class="timer-content">
                <div class="timer-meta">
                    <span class="timer-dot"></span>
                    <span>Tracking now</span>
                </div>
                <div class="timer-title">@TimerState.ActiveTaskTitle</div>
                <div class="timer-elapsed">@FormatHms(TimerState.ElapsedSeconds)</div>
            </div>
            <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Class="timer-arrow" />
        </div>
    }
    else if (!_loading && _boards is not null && _boards.Count > 0)
    {
        <div class="quick-start">
            <MudIcon Icon="@Icons.Material.Outlined.Timer" Class="quick-start-icon" />
            <MudSelect T="int" Value="_quickBoardId" ValueChanged="OnQuickBoardChanged"
                       Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true"
                       Placeholder="Board" Style="min-width: 140px; flex: 0 0 160px;">
                @foreach (var b in _boards)
                {
                    <MudSelectItem T="int" Value="@b.Id">@b.Name</MudSelectItem>
                }
            </MudSelect>
            <MudSelect T="int?" @bind-Value="_quickTaskId"
                       Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true"
                       Placeholder="Task — optional" Style="min-width: 160px; flex: 0 0 200px;"
                       Disabled="_quickBoardId == 0">
                <MudSelectItem T="int?" Value="@((int?)null)">No task (free)</MudSelectItem>
                @if (_quickBoardTasks is not null)
                {
                    @foreach (var t in _quickBoardTasks)
                    {
                        <MudSelectItem T="int?" Value="@((int?)t.Id)">@t.Title</MudSelectItem>
                    }
                }
            </MudSelect>
            <MudTextField T="string" @bind-Value="_quickNotes"
                          Placeholder="What working on?"
                          Variant="Variant.Outlined" Margin="Margin.Dense"
                          Style="flex: 1; min-width: 0;" Immediate="true"
                          OnKeyDown="HandleQuickKeyDown" />
            <MudIconButton Icon="@Icons.Material.Filled.PlayArrow"
                           Color="Color.Secondary" Size="Size.Medium"
                           OnClick="StartQuickTimer"
                           Disabled="_quickStarting || _quickBoardId == 0"
                           Class="quick-start-play" />
        </div>
    }

    <div class="stats-row">
        <div class="stat-card">
            <div class="stat-label">Today</div>
            <div class="stat-value">
                @if (_loading) { <span class="stat-skel"></span> }
                else { @FormatHm(_summary?.TodaySeconds ?? 0) }
            </div>
            <div class="stat-sub">
                @if (!_loading) { @($"{_summary?.TodayEntryCount ?? 0} entries") }
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Last 7 days</div>
            <div class="stat-value">
                @if (_loading) { <span class="stat-skel"></span> }
                else { @FormatHm(_summary?.WeekSeconds ?? 0) }
            </div>
            <div class="stat-sub">
                @if (!_loading) { @($"{_summary?.WeekEntryCount ?? 0} entries") }
            </div>
            @if (!_loading && _daily is not null && _daily.Count > 0)
            {
                <div class="sparkline" title="Last 7 days">
                    @{ var maxSeconds = Math.Max(1, _daily.Max(d => d.Seconds)); }
                    @foreach (var d in _daily)
                    {
                        var heightPct = d.Seconds == 0 ? 6 : Math.Max(8, (int)(d.Seconds * 100.0 / maxSeconds));
                        var isToday = d.Date.Date == DateTime.Now.Date;
                        var tip = $"{d.Date:ddd} · {FormatHm(d.Seconds)}";
                        <div class="spark-bar @(isToday ? "today" : "") @(d.Seconds == 0 ? "empty" : "")"
                             style="height: @(heightPct)%;" title="@tip"></div>
                    }
                </div>
            }
        </div>
        <div class="stat-card">
            <div class="stat-label">Boards</div>
            <div class="stat-value">
                @if (_loading) { <span class="stat-skel"></span> }
                else { @(_boards?.Count ?? 0) }
            </div>
            <div class="stat-sub">
                @if (!_loading && _boards is not null) { @($"{_boards.Sum(b => b.TaskCount)} tasks") }
            </div>
        </div>
    </div>

    @if (!_loading && _topTasks is not null && _topTasks.Count > 0)
    {
        <div class="section-title">
            <MudText Typo="Typo.h6" Style="font-weight: 600; letter-spacing: -0.02em;">Top tasks this week</MudText>
        </div>
        <div class="top-tasks">
            @foreach (var t in _topTasks)
            {
                <div class="top-task-row" @onclick="@(() => Navigation.NavigateTo($"/boards/{t.BoardId}"))">
                    <span class="top-task-dot" style="@($"background: {t.BoardColor ?? "#007AFF"};")"></span>
                    <div class="top-task-text">
                        <div class="top-task-title">@t.TaskTitle</div>
                        <div class="top-task-board">@t.BoardName</div>
                    </div>
                    <div class="top-task-time">@FormatHm(t.Seconds)</div>
                </div>
            }
        </div>
    }

    <div class="section-title">
        <MudText Typo="Typo.h6" Style="font-weight: 600; letter-spacing: -0.02em;">Boards</MudText>
    </div>

    @if (_loading)
    {
        <div class="boards-grid">
            @for (int i = 0; i < 3; i++)
            {
                <div class="board-card-skel"></div>
            }
        </div>
    }
    else if (_boards is null || _boards.Count == 0)
    {
        <div class="empty-state">
            <MudIcon Icon="@Icons.Material.Outlined.Dashboard" Style="font-size: 56px; color: var(--mud-palette-text-secondary); opacity: 0.6;" />
            <MudText Typo="Typo.h6" Class="mt-3" Style="font-weight: 600;">No boards yet</MudText>
            <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);" Class="mt-1 mb-4">
                Create your first board to get started.
            </MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       Href="/boards"
                       Style="border-radius: 980px; padding: 8px 20px; font-weight: 500;">
                Create Board
            </MudButton>
        </div>
    }
    else
    {
        <div class="boards-grid">
            @foreach (var board in _boards)
            {
                <div class="board-card" @onclick="@(() => Navigation.NavigateTo($"/boards/{board.Id}"))">
                    <div class="board-card-accent" style="@($"background: {board.Color ?? "#007AFF"};")"></div>
                    <div class="board-card-body">
                        <div class="board-card-icon">
                            <MudIcon Icon="@(board.Icon ?? Icons.Material.Filled.Dashboard)"
                                     Style="@($"font-size: 22px; color: {board.Color ?? "#007AFF"};")" />
                        </div>
                        <div class="board-card-name">@board.Name</div>
                        <div class="board-card-meta">
                            <span>@board.TaskCount @(board.TaskCount == 1 ? "task" : "tasks")</span>
                            <span class="dot">·</span>
                            <span>@board.ColumnCount @(board.ColumnCount == 1 ? "column" : "columns")</span>
                        </div>
                        @if (board.WeekSeconds > 0)
                        {
                            <div class="board-card-time">
                                <span>@FormatHm(board.TodaySeconds) today</span>
                                <span class="dot">·</span>
                                <span>@FormatHm(board.WeekSeconds) this week</span>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .dashboard-root {
        max-width: 1100px;
        margin: 0 auto;
        padding: 8px 4px 48px;
        animation: fadeUp 0.4s cubic-bezier(0.0, 0.0, 0.2, 1.0);
    }

    @@keyframes fadeUp {
        from { opacity: 0; transform: translateY(8px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .dashboard-header {
        margin-bottom: 32px;
    }

    .timer-hero {
        position: relative;
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 20px 24px;
        margin-bottom: 24px;
        background: linear-gradient(135deg, #007AFF 0%, #0051D5 100%);
        color: #fff;
        border-radius: 18px;
        cursor: pointer;
        overflow: hidden;
        box-shadow: 0 8px 24px rgba(0, 122, 255, 0.25);
        transition: transform 0.2s cubic-bezier(0.0, 0.0, 0.2, 1.0), box-shadow 0.2s;
    }

    .timer-hero:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 32px rgba(0, 122, 255, 0.32);
    }

    .timer-pulse {
        position: absolute;
        top: -50%;
        right: -10%;
        width: 240px;
        height: 240px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(255,255,255,0.18) 0%, transparent 70%);
        animation: pulse 3s ease-in-out infinite;
    }

    @@keyframes pulse {
        0%, 100% { transform: scale(1); opacity: 0.6; }
        50% { transform: scale(1.15); opacity: 0.9; }
    }

    .timer-content { flex: 1; position: relative; z-index: 1; }

    .timer-meta {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.75rem;
        font-weight: 500;
        opacity: 0.85;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .timer-dot {
        width: 8px; height: 8px; border-radius: 50%;
        background: #fff;
        box-shadow: 0 0 0 0 rgba(255,255,255,0.7);
        animation: dotPulse 1.5s ease-in-out infinite;
    }

    @@keyframes dotPulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(255,255,255,0.7); }
        50% { box-shadow: 0 0 0 6px rgba(255,255,255,0); }
    }

    .timer-title {
        font-size: 1.0625rem;
        font-weight: 600;
        margin-top: 6px;
        letter-spacing: -0.014em;
    }

    .timer-elapsed {
        font-size: 1.75rem;
        font-weight: 600;
        margin-top: 4px;
        letter-spacing: -0.025em;
        font-feature-settings: "tnum";
    }

    .timer-arrow {
        position: relative;
        z-index: 1;
        font-size: 24px !important;
        opacity: 0.7;
        transition: transform 0.2s, opacity 0.2s;
    }

    .timer-hero:hover .timer-arrow {
        opacity: 1;
        transform: translateX(4px);
    }

    .quick-start {
        display: flex;
        align-items: center;
        gap: 10px;
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 16px;
        padding: 10px 14px;
        margin-bottom: 24px;
        transition: border-color 0.2s;
    }

    .quick-start:focus-within {
        border-color: rgba(0, 122, 255, 0.35);
    }

    .quick-start-icon {
        font-size: 20px !important;
        color: var(--mud-palette-text-secondary);
        opacity: 0.6;
        flex: 0 0 auto;
    }

    .quick-start-play {
        flex: 0 0 auto;
    }

    .stats-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px;
        margin-bottom: 36px;
    }

    .stat-card {
        background: var(--mud-palette-surface);
        border-radius: 16px;
        padding: 20px 22px;
        border: 1px solid var(--mud-palette-divider);
        transition: transform 0.2s, border-color 0.2s;
    }

    .stat-card:hover {
        transform: translateY(-1px);
        border-color: rgba(0, 122, 255, 0.18);
    }

    .stat-label {
        font-size: 0.75rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--mud-palette-text-secondary);
    }

    .stat-value {
        font-size: 1.875rem;
        font-weight: 600;
        margin-top: 8px;
        letter-spacing: -0.025em;
        font-feature-settings: "tnum";
        min-height: 36px;
    }

    .stat-sub {
        font-size: 0.8125rem;
        color: var(--mud-palette-text-secondary);
        margin-top: 2px;
        min-height: 20px;
    }

    .stat-skel {
        display: inline-block;
        width: 80px; height: 28px;
        background: var(--mud-palette-background-gray);
        border-radius: 6px;
        animation: shimmer 1.5s ease-in-out infinite;
    }

    .sparkline {
        display: flex;
        align-items: flex-end;
        gap: 4px;
        height: 32px;
        margin-top: 12px;
    }

    .spark-bar {
        flex: 1;
        min-height: 2px;
        background: var(--mud-palette-divider);
        border-radius: 2px;
        transition: opacity 0.15s, transform 0.15s;
    }

    .spark-bar.today {
        background: var(--mud-palette-primary);
    }

    .spark-bar.empty {
        opacity: 0.4;
    }

    .spark-bar:hover {
        opacity: 1;
        transform: scaleY(1.05);
    }

    @@keyframes shimmer {
        0%, 100% { opacity: 0.6; }
        50% { opacity: 0.9; }
    }

    .section-title {
        margin-bottom: 14px;
    }

    .top-tasks {
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 16px;
        padding: 6px 0;
        margin-bottom: 36px;
    }

    .top-task-row {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 12px 18px;
        cursor: pointer;
        transition: background 0.15s;
        border-bottom: 1px solid var(--mud-palette-divider);
    }

    .top-task-row:last-child {
        border-bottom: none;
    }

    .top-task-row:hover {
        background: var(--mud-palette-background-gray);
    }

    .top-task-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex: 0 0 auto;
    }

    .top-task-text {
        flex: 1;
        min-width: 0;
    }

    .top-task-title {
        font-size: 0.9375rem;
        font-weight: 600;
        letter-spacing: -0.01em;
        color: var(--mud-palette-text-primary);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .top-task-board {
        font-size: 0.75rem;
        color: var(--mud-palette-text-secondary);
        margin-top: 2px;
    }

    .top-task-time {
        font-size: 0.9375rem;
        font-weight: 600;
        font-feature-settings: "tnum";
        letter-spacing: -0.01em;
        color: var(--mud-palette-text-primary);
    }

    .boards-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 14px;
    }

    .board-card {
        position: relative;
        background: var(--mud-palette-surface);
        border-radius: 16px;
        padding: 0;
        border: 1px solid var(--mud-palette-divider);
        cursor: pointer;
        overflow: hidden;
        transition: transform 0.2s cubic-bezier(0.0, 0.0, 0.2, 1.0), box-shadow 0.2s, border-color 0.2s;
    }

    .board-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px var(--mud-palette-overlay-dark);
        border-color: transparent;
    }

    .board-card-accent {
        height: 4px;
        opacity: 0.85;
    }

    .board-card-body {
        padding: 18px 20px 20px;
    }

    .board-card-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 36px; height: 36px;
        border-radius: 10px;
        background: var(--mud-palette-background-gray);
        margin-bottom: 12px;
    }

    .board-card-name {
        font-size: 1rem;
        font-weight: 600;
        letter-spacing: -0.014em;
        color: var(--mud-palette-text-primary);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .board-card-meta {
        font-size: 0.8125rem;
        color: var(--mud-palette-text-secondary);
        margin-top: 4px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .board-card-meta .dot { opacity: 0.5; }

    .board-card-time {
        font-size: 0.8125rem;
        color: var(--mud-palette-text-secondary);
        margin-top: 6px;
        display: flex;
        align-items: center;
        gap: 6px;
        font-feature-settings: "tnum";
    }

    .board-card-time .dot { opacity: 0.5; }

    .board-card-skel {
        height: 120px;
        border-radius: 16px;
        background: var(--mud-palette-background-gray);
        animation: shimmer 1.5s ease-in-out infinite;
    }

    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 56px 24px;
        background: var(--mud-palette-surface);
        border-radius: 16px;
        border: 1px solid var(--mud-palette-divider);
    }

    @@media (max-width: 720px) {
        .stats-row { grid-template-columns: 1fr; }
        .quick-start { flex-wrap: wrap; }
        .quick-start > * { flex: 1 1 calc(50% - 6px) !important; }
    }
</style>

@code {
    private bool _loading = true;
    private List<BoardSummaryResponse>? _boards;
    private TimeSummaryResponse? _summary;
    private List<DailyTotalResponse>? _daily;
    private List<TopTaskResponse>? _topTasks;
    private string _greeting = "Hello";
    private string _userName = string.Empty;
    private string _dateLabel = string.Empty;

    private int _quickBoardId;
    private int? _quickTaskId;
    private string? _quickNotes;
    private bool _quickStarting;
    private List<BoardTaskItem>? _quickBoardTasks;

    protected override async Task OnInitializedAsync()
    {
        TimerState.OnTimerChanged += HandleTimerChanged;

        var now = DateTime.Now;
        _greeting = now.Hour < 5 ? "Good night"
                  : now.Hour < 12 ? "Good morning"
                  : now.Hour < 18 ? "Good afternoon"
                  : "Good evening";
        _dateLabel = now.ToString("dddd, MMMM d");

        try
        {
            var auth = await AuthState.GetAuthenticationStateAsync();
            var name = auth.User.Identity?.Name ?? "";
            _userName = name.Contains('@') ? name.Split('@')[0] : name;
            if (!string.IsNullOrEmpty(_userName))
                _userName = char.ToUpper(_userName[0]) + _userName[1..];
        }
        catch { }

        try
        {
            var boardsTask = BoardService.GetBoardsAsync();
            var summaryTask = TimeEntryService.GetSummaryAsync();
            var dailyTask = TimeEntryService.GetDailyAsync(7);
            var topTasksTask = TimeEntryService.GetTopTasksAsync(7, 5);
            await Task.WhenAll(boardsTask, summaryTask, dailyTask, topTasksTask);
            _boards = boardsTask.Result;
            _summary = summaryTask.Result;
            _daily = dailyTask.Result;
            _topTasks = topTasksTask.Result;

            if (_boards.Count > 0)
                _quickBoardId = _boards[0].Id;
        }
        catch
        {
            _boards ??= [];
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnQuickBoardChanged(int boardId)
    {
        _quickBoardId = boardId;
        _quickTaskId = null;
        _quickBoardTasks = null;
        if (boardId == 0) return;
        try { _quickBoardTasks = await BoardService.GetBoardTasksAsync(boardId); }
        catch { _quickBoardTasks = []; }
    }

    private async Task HandleQuickKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !_quickStarting && _quickBoardId != 0)
            await StartQuickTimer();
    }

    private async Task StartQuickTimer()
    {
        if (_quickBoardId == 0 || _quickStarting) return;
        _quickStarting = true;
        try
        {
            HttpResponseMessage response;
            if (_quickTaskId.HasValue)
            {
                response = await TimeEntryService.StartTimerAsync(_quickTaskId.Value);
            }
            else
            {
                response = await TimeEntryService.StartBoardTimerAsync(_quickBoardId,
                    new StartBoardTimerRequest { Notes = string.IsNullOrWhiteSpace(_quickNotes) ? null : _quickNotes });
            }

            if (response.StatusCode == System.Net.HttpStatusCode.Conflict)
            {
                Snackbar.Add("Timer already running. Stop it first.", Severity.Warning);
                return;
            }
            if (!response.IsSuccessStatusCode)
            {
                Snackbar.Add("Could not start timer.", Severity.Error);
                return;
            }

            var active = await TimeEntryService.GetActiveTimerAsync();
            if (active is not null)
                TimerState.SetActive(active.TaskId, active.TaskTitle, active.BoardId, active.BoardName, active.EntryId, active.StartTime);

            _quickNotes = null;
            _quickTaskId = null;
        }
        catch
        {
            Snackbar.Add("Could not start timer.", Severity.Error);
        }
        finally
        {
            _quickStarting = false;
        }
    }

    private void HandleTimerChanged() => InvokeAsync(StateHasChanged);

    private void OpenActiveTask()
    {
        if (TimerState.ActiveTaskId is not int taskId) return;
        // Navigate to first board where this task lives — fallback open on /boards
        Navigation.NavigateTo("/boards");
    }

    private static string FormatHms(int seconds)
    {
        var ts = TimeSpan.FromSeconds(seconds);
        return $"{(int)ts.TotalHours:D2}:{ts.Minutes:D2}:{ts.Seconds:D2}";
    }

    private static string FormatHm(int seconds)
    {
        var ts = TimeSpan.FromSeconds(seconds);
        var h = (int)ts.TotalHours;
        var m = ts.Minutes;
        if (h == 0 && m == 0) return "0m";
        if (h == 0) return $"{m}m";
        if (m == 0) return $"{h}h";
        return $"{h}h {m}m";
    }

    public void Dispose()
    {
        TimerState.OnTimerChanged -= HandleTimerChanged;
    }
}
