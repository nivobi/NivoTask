@page "/"
@page "/dashboard"
@attribute [Authorize]
@using NivoTask.Shared.Dtos.TimeEntries
@using NivoTask.Client.Models
@implements IDisposable
@inject BoardService BoardService
@inject TimeEntryService TimeEntryService
@inject TimerStateService TimerState
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthState
@inject ISnackbar Snackbar
@inject LocalStorageService LocalStorage

<div class="dashboard-root">
    <div class="dashboard-header">
        <div class="dashboard-header-text">
            <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary); font-weight: 500;">
                @_dateLabel
            </MudText>
            <MudText Typo="Typo.h3" Style="font-weight: 600; letter-spacing: -0.03em; margin-top: 4px;">
                @_greeting@(string.IsNullOrEmpty(_userName) ? "" : $", {_userName}")
            </MudText>
        </div>
        <button class="export-link" type="button" @onclick="OpenExportDialog"
                title="Download time entries as CSV">
            <MudIcon Icon="@Icons.Material.Outlined.FileDownload" Style="font-size: 16px;" />
            Export CSV
        </button>

        <MudDialog @bind-Visible="_exportDialogOpen" Options="@(new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true })">
            <TitleContent>
                <MudText Typo="Typo.h6">Export time entries</MudText>
            </TitleContent>
            <DialogContent>
                <MudDateRangePicker @bind-DateRange="_exportRange" Label="Date range"
                                    PickerVariant="PickerVariant.Static"
                                    MaxDate="DateTime.Today" />
            </DialogContent>
            <DialogActions>
                <MudButton OnClick="@(() => _exportDialogOpen = false)">Cancel</MudButton>
                <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="DoExport">
                    Download
                </MudButton>
            </DialogActions>
        </MudDialog>
    </div>

    @if (TimerState.IsRunning)
    {
        <div class="timer-hero" @onclick="OpenActiveTask">
            <div class="timer-pulse"></div>
            <div class="timer-content">
                <div class="timer-meta">
                    <span class="timer-dot"></span>
                    <span>Tracking now</span>
                </div>
                <div class="timer-title">@TimerState.ActiveTaskTitle</div>
                <div class="timer-elapsed">@FormatHms(TimerState.ElapsedSeconds)</div>
            </div>
            <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Class="timer-arrow" />
        </div>
    }
    else if (!_loading && _boards is not null && _boards.Count > 0)
    {
        <div class="quick-start">
            <MudIcon Icon="@Icons.Material.Outlined.Timer" Class="quick-start-icon" />
            <MudSelect T="int" Value="_quickBoardId" ValueChanged="OnQuickBoardChanged"
                       Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true"
                       Placeholder="Board" Style="min-width: 140px; flex: 0 0 160px;">
                @foreach (var b in _boards)
                {
                    <MudSelectItem T="int" Value="@b.Id">@b.Name</MudSelectItem>
                }
            </MudSelect>
            <MudSelect T="int?" @bind-Value="_quickTaskId"
                       Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true"
                       Placeholder="Task — optional" Style="min-width: 160px; flex: 0 0 200px;"
                       Disabled="_quickBoardId == 0">
                <MudSelectItem T="int?" Value="@((int?)null)">No task (free)</MudSelectItem>
                @if (_quickBoardTasks is not null)
                {
                    @foreach (var t in _quickBoardTasks)
                    {
                        <MudSelectItem T="int?" Value="@((int?)t.Id)">@t.Title</MudSelectItem>
                    }
                }
            </MudSelect>
            <MudTextField T="string" @bind-Value="_quickNotes"
                          Placeholder="What working on?"
                          Variant="Variant.Outlined" Margin="Margin.Dense"
                          Style="flex: 1; min-width: 0;" Immediate="true"
                          OnKeyDown="HandleQuickKeyDown" />
            <MudIconButton Icon="@Icons.Material.Filled.PlayArrow"
                           Color="Color.Secondary" Size="Size.Medium"
                           OnClick="StartQuickTimer"
                           Disabled="_quickStarting || _quickBoardId == 0"
                           Class="quick-start-play" />
        </div>
    }

    <div class="stats-row">
        <div class="stat-card">
            <div class="stat-label-row">
                <span class="stat-label">Today</span>
                @if (!_loading)
                {
                    @if (_editingDailyGoal)
                    {
                        <input type="number" min="0" max="1440" @bind-value="_dailyGoalDraft"
                               class="stat-goal-input" @onkeydown="HandleDailyGoalKeyDown" autofocus />
                        <button class="stat-goal-btn" @onclick="SaveDailyGoal">✓</button>
                    }
                    else
                    {
                        <button class="stat-goal-edit" @onclick="StartEditDailyGoal"
                                title="Set daily goal (minutes)">
                            @(_dailyGoalMinutes > 0 ? $"goal {FormatHm(_dailyGoalMinutes * 60)}" : "set goal")
                        </button>
                    }
                }
            </div>
            <div class="stat-value">
                @if (_loading) { <span class="stat-skel"></span> }
                else { @FormatHm(_summary?.TodaySeconds ?? 0) }
            </div>
            <div class="stat-sub">
                @if (!_loading) { @($"{_summary?.TodayEntryCount ?? 0} entries") }
            </div>
            @if (!_loading && _dailyGoalMinutes > 0)
            {
                var goalSec = _dailyGoalMinutes * 60;
                var pct = Math.Min(100, (int)((_summary?.TodaySeconds ?? 0) * 100.0 / goalSec));
                var hit = (_summary?.TodaySeconds ?? 0) >= goalSec;
                <div class="goal-bar">
                    <div class="goal-bar-fill @(hit ? "hit" : "")" style="width: @(pct)%;"></div>
                </div>
            }
        </div>
        <div class="stat-card">
            <div class="stat-label-row">
                <span class="stat-label">Last 7 days</span>
                @if (!_loading)
                {
                    @if (_editingWeeklyGoal)
                    {
                        <input type="number" min="0" max="10080" @bind-value="_weeklyGoalDraft"
                               class="stat-goal-input" @onkeydown="HandleWeeklyGoalKeyDown" autofocus />
                        <button class="stat-goal-btn" @onclick="SaveWeeklyGoal">✓</button>
                    }
                    else
                    {
                        <button class="stat-goal-edit" @onclick="StartEditWeeklyGoal"
                                title="Set weekly goal (minutes)">
                            @(_weeklyGoalMinutes > 0 ? $"goal {FormatHm(_weeklyGoalMinutes * 60)}" : "set goal")
                        </button>
                    }
                }
            </div>
            <div class="stat-value">
                @if (_loading) { <span class="stat-skel"></span> }
                else { @FormatHm(_summary?.WeekSeconds ?? 0) }
            </div>
            <div class="stat-sub">
                @if (!_loading)
                {
                    @($"{_summary?.WeekEntryCount ?? 0} entries")
                    @if (_summary is not null && _summary.PreviousWeekSeconds > 0)
                    {
                        var delta = _summary.WeekSeconds - _summary.PreviousWeekSeconds;
                        var sign = delta >= 0 ? "+" : "−";
                        var cls = delta >= 0 ? "delta-up" : "delta-down";
                        <span class="stat-delta @cls" title="Compared to previous 7 days">
                            @sign@FormatHm(Math.Abs(delta)) vs prev
                        </span>
                    }
                }
            </div>
            @if (!_loading && _weeklyGoalMinutes > 0)
            {
                var goalSec = _weeklyGoalMinutes * 60;
                var pct = Math.Min(100, (int)((_summary?.WeekSeconds ?? 0) * 100.0 / goalSec));
                var hit = (_summary?.WeekSeconds ?? 0) >= goalSec;
                <div class="goal-bar">
                    <div class="goal-bar-fill @(hit ? "hit" : "")" style="width: @(pct)%;"></div>
                </div>
            }
            @if (!_loading && _daily is not null && _daily.Count > 0)
            {
                <div class="sparkline" title="Last 7 days">
                    @{ var maxSeconds = Math.Max(1, _daily.Max(d => d.Seconds)); }
                    @foreach (var d in _daily)
                    {
                        var heightPct = d.Seconds == 0 ? 6 : Math.Max(8, (int)(d.Seconds * 100.0 / maxSeconds));
                        var isToday = d.Date.Date == DateTime.Now.Date;
                        var tip = $"{d.Date:ddd} · {FormatHm(d.Seconds)}";
                        <div class="spark-bar @(isToday ? "today" : "") @(d.Seconds == 0 ? "empty" : "")"
                             style="height: @(heightPct)%;" title="@tip"></div>
                    }
                </div>
            }
        </div>
        <div class="stat-card">
            <div class="stat-label">Boards</div>
            <div class="stat-value">
                @if (_loading) { <span class="stat-skel"></span> }
                else { @(_boards?.Count ?? 0) }
            </div>
            <div class="stat-sub">
                @if (!_loading && _boards is not null) { @($"{_boards.Sum(b => b.TaskCount)} tasks") }
            </div>
        </div>
    </div>

    @if (!_loading && _heatmap is not null && _heatmap.Any(d => d.Seconds > 0))
    {
        var weekStartDow = DayOfWeek.Monday;
            var seconds = _heatmap.ToDictionary(h => h.Date.Date, h => h.Seconds);
            var firstDate = _heatmap[0].Date.Date;
            var today = DateTime.Now.Date;
            var offset = ((int)firstDate.DayOfWeek - (int)weekStartDow + 7) % 7;
            var gridStart = firstDate.AddDays(-offset);
            var totalDays = (today - gridStart).Days + 1;
            var weekCount = (totalDays + 6) / 7;
            var maxHm = Math.Max(1, _heatmap.Max(d => d.Seconds));
            var totalSeconds = _heatmap.Sum(d => d.Seconds);

            var monthLabels = new Dictionary<int, string>();
            var seenMonth = "";
            for (int w = 0; w < weekCount; w++)
            {
                var colDate = gridStart.AddDays(w * 7);
                var label = colDate.ToString("MMM");
                if (label != seenMonth) { monthLabels[w] = label; seenMonth = label; }
            }
            var dayNames = new[] { "Mon", "", "Wed", "", "Fri", "", "" };

        <div class="heatmap-card">
            <div class="heatmap-header">
                <MudText Typo="Typo.h6" Style="font-weight: 600; letter-spacing: -0.02em;">
                    Activity · last 12 weeks
                </MudText>
                <span class="heatmap-total">@FormatHm(totalSeconds) tracked</span>
            </div>
            <div class="heatmap-months" style="grid-template-columns: 32px repeat(@weekCount, 1fr);">
                <div></div>
                @for (int w = 0; w < weekCount; w++)
                {
                    <div class="heatmap-month-label">@(monthLabels.TryGetValue(w, out var m) ? m : "")</div>
                }
            </div>
            <div class="heatmap-grid" style="grid-template-columns: 32px repeat(@weekCount, 1fr);">
                <div class="heatmap-rowlabels">
                    @foreach (var name in dayNames)
                    {
                        <div class="heatmap-row-label">@name</div>
                    }
                </div>
                @for (int w = 0; w < weekCount; w++)
                {
                    <div class="heatmap-col">
                        @for (int dow = 0; dow < 7; dow++)
                        {
                            var date = gridStart.AddDays(w * 7 + dow);
                            if (date > today || date < firstDate)
                            {
                                <div class="heatmap-cell heatmap-bucket-empty"></div>
                            }
                            else
                            {
                                var sec = seconds.TryGetValue(date, out var s) ? s : 0;
                                var bucket = sec == 0 ? 0
                                    : sec < maxHm * 0.25 ? 1
                                    : sec < maxHm * 0.5 ? 2
                                    : sec < maxHm * 0.75 ? 3
                                    : 4;
                                var isToday = date == today;
                                <div class="heatmap-cell heatmap-bucket-@bucket @(isToday ? "today" : "")"
                                     title="@date.ToString("ddd, MMM d") · @FormatHm(sec)"></div>
                            }
                        }
                    </div>
                }
            </div>
            <div class="heatmap-legend">
                <span>Less</span>
                <div class="heatmap-cell heatmap-bucket-0"></div>
                <div class="heatmap-cell heatmap-bucket-1"></div>
                <div class="heatmap-cell heatmap-bucket-2"></div>
                <div class="heatmap-cell heatmap-bucket-3"></div>
                <div class="heatmap-cell heatmap-bucket-4"></div>
                <span>More</span>
            </div>
        </div>
    }

    @if (!_loading && _topTasks is not null && _topTasks.Count > 0)
    {
        <div class="section-title">
            <MudText Typo="Typo.h6" Style="font-weight: 600; letter-spacing: -0.02em;">Top tasks this week</MudText>
        </div>
        <div class="top-tasks">
            @foreach (var t in _topTasks)
            {
                <div class="top-task-row" @onclick="@(() => Navigation.NavigateTo($"/boards/{t.BoardId}"))">
                    <span class="top-task-dot" style="@($"background: {t.BoardColor ?? "#007AFF"};")"></span>
                    <div class="top-task-text">
                        <div class="top-task-title">@t.TaskTitle</div>
                        <div class="top-task-board">@t.BoardName</div>
                    </div>
                    <div class="top-task-time">@FormatHm(t.Seconds)</div>
                </div>
            }
        </div>
    }

    <div class="section-title">
        <MudText Typo="Typo.h6" Style="font-weight: 600; letter-spacing: -0.02em;">Boards</MudText>
    </div>

    @if (_loading)
    {
        <div class="boards-grid">
            @for (int i = 0; i < 3; i++)
            {
                <div class="board-card-skel"></div>
            }
        </div>
    }
    else if (_boards is null || _boards.Count == 0)
    {
        <div class="empty-state">
            <MudIcon Icon="@Icons.Material.Outlined.Dashboard" Style="font-size: 56px; color: var(--mud-palette-text-secondary); opacity: 0.6;" />
            <MudText Typo="Typo.h6" Class="mt-3" Style="font-weight: 600;">No boards yet</MudText>
            <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);" Class="mt-1 mb-4">
                Create your first board to get started.
            </MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       Href="/boards"
                       Style="border-radius: 980px; padding: 8px 20px; font-weight: 500;">
                Create Board
            </MudButton>
        </div>
    }
    else
    {
        <div class="boards-grid">
            @foreach (var board in _boards)
            {
                <div class="board-card" @onclick="@(() => Navigation.NavigateTo($"/boards/{board.Id}"))">
                    <div class="board-card-accent" style="@($"background: {board.Color ?? "#007AFF"};")"></div>
                    <div class="board-card-body">
                        <div class="board-card-icon">
                            <MudIcon Icon="@(board.Icon ?? Icons.Material.Filled.Dashboard)"
                                     Style="@($"font-size: 22px; color: {board.Color ?? "#007AFF"};")" />
                        </div>
                        <div class="board-card-name">@board.Name</div>
                        <div class="board-card-meta">
                            <span>@board.TaskCount @(board.TaskCount == 1 ? "task" : "tasks")</span>
                            <span class="dot">·</span>
                            <span>@board.ColumnCount @(board.ColumnCount == 1 ? "column" : "columns")</span>
                        </div>
                        @if (board.WeekSeconds > 0)
                        {
                            <div class="board-card-time">
                                <span>@FormatHm(board.TodaySeconds) today</span>
                                <span class="dot">·</span>
                                <span>@FormatHm(board.WeekSeconds) this week</span>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }

    @if (!_loading && _archivedBoards is not null && _archivedBoards.Count > 0)
    {
        <div class="archived-section">
            <button class="archived-toggle" @onclick="() => _showArchived = !_showArchived">
                <MudIcon Icon="@(_showArchived ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                         Style="font-size: 18px;" />
                <span>Archived (@_archivedBoards.Count)</span>
            </button>
            @if (_showArchived)
            {
                <div class="archived-grid">
                    @foreach (var b in _archivedBoards)
                    {
                        <div class="archived-row">
                            <span class="archived-dot" style="@($"background: {b.Color ?? "#888"};")"></span>
                            <span class="archived-name">@b.Name</span>
                            <span class="archived-meta">@b.TaskCount @(b.TaskCount == 1 ? "task" : "tasks")</span>
                            <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Default"
                                       OnClick="() => RestoreBoard(b.Id)"
                                       StartIcon="@Icons.Material.Outlined.Unarchive">
                                Restore
                            </MudButton>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

<style>
    .dashboard-root {
        max-width: 1100px;
        margin: 0 auto;
        padding: 8px 4px 48px;
        animation: fadeUp 0.4s cubic-bezier(0.0, 0.0, 0.2, 1.0);
    }

    @@keyframes fadeUp {
        from { opacity: 0; transform: translateY(8px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .dashboard-header {
        margin-bottom: 32px;
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 16px;
    }

    .dashboard-header-text { flex: 1; min-width: 0; }

    .export-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 12px;
        border-radius: 980px;
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
        color: var(--mud-palette-text-secondary);
        font-size: 0.8125rem;
        font-weight: 500;
        text-decoration: none;
        transition: border-color 0.2s, color 0.2s, transform 0.2s;
        flex-shrink: 0;
    }

    .export-link:hover {
        border-color: rgba(0, 122, 255, 0.35);
        color: var(--mud-palette-text-primary);
        transform: translateY(-1px);
    }

    .stat-delta {
        display: inline-block;
        margin-left: 8px;
        padding: 1px 8px;
        border-radius: 980px;
        font-size: 0.6875rem;
        font-weight: 600;
        font-feature-settings: "tnum";
    }

    .stat-delta.delta-up {
        background: rgba(54, 179, 126, 0.12);
        color: #36b37e;
    }

    .stat-delta.delta-down {
        background: rgba(255, 159, 10, 0.12);
        color: #FF9F0A;
    }

    .archived-section {
        margin-top: 36px;
    }

    .archived-toggle {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: transparent;
        border: none;
        color: var(--mud-palette-text-secondary);
        font-size: 0.8125rem;
        font-weight: 500;
        cursor: pointer;
        padding: 6px 8px;
        border-radius: 8px;
        transition: background 0.15s;
    }

    .archived-toggle:hover { background: var(--mud-palette-background-gray); }

    .archived-grid {
        margin-top: 12px;
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 14px;
        overflow: hidden;
    }

    .archived-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 16px;
        border-bottom: 1px solid var(--mud-palette-divider);
        font-size: 0.875rem;
    }

    .archived-row:last-child { border-bottom: none; }

    .archived-dot {
        width: 8px; height: 8px; border-radius: 50%; flex: 0 0 auto;
    }

    .archived-name {
        font-weight: 500;
        color: var(--mud-palette-text-primary);
        flex: 1;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .archived-meta {
        font-size: 0.75rem;
        color: var(--mud-palette-text-secondary);
    }

    .timer-hero {
        position: relative;
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 20px 24px;
        margin-bottom: 24px;
        background: linear-gradient(135deg, #007AFF 0%, #0051D5 100%);
        color: #fff;
        border-radius: 18px;
        cursor: pointer;
        overflow: hidden;
        box-shadow: 0 8px 24px rgba(0, 122, 255, 0.25);
        transition: transform 0.2s cubic-bezier(0.0, 0.0, 0.2, 1.0), box-shadow 0.2s;
    }

    .timer-hero:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 32px rgba(0, 122, 255, 0.32);
    }

    .timer-pulse {
        position: absolute;
        top: -50%;
        right: -10%;
        width: 240px;
        height: 240px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(255,255,255,0.18) 0%, transparent 70%);
        animation: pulse 3s ease-in-out infinite;
    }

    @@keyframes pulse {
        0%, 100% { transform: scale(1); opacity: 0.6; }
        50% { transform: scale(1.15); opacity: 0.9; }
    }

    .timer-content { flex: 1; position: relative; z-index: 1; }

    .timer-meta {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.75rem;
        font-weight: 500;
        opacity: 0.85;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .timer-dot {
        width: 8px; height: 8px; border-radius: 50%;
        background: #fff;
        box-shadow: 0 0 0 0 rgba(255,255,255,0.7);
        animation: dotPulse 1.5s ease-in-out infinite;
    }

    @@keyframes dotPulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(255,255,255,0.7); }
        50% { box-shadow: 0 0 0 6px rgba(255,255,255,0); }
    }

    .timer-title {
        font-size: 1.0625rem;
        font-weight: 600;
        margin-top: 6px;
        letter-spacing: -0.014em;
    }

    .timer-elapsed {
        font-size: 1.75rem;
        font-weight: 600;
        margin-top: 4px;
        letter-spacing: -0.025em;
        font-feature-settings: "tnum";
    }

    .timer-arrow {
        position: relative;
        z-index: 1;
        font-size: 24px !important;
        opacity: 0.7;
        transition: transform 0.2s, opacity 0.2s;
    }

    .timer-hero:hover .timer-arrow {
        opacity: 1;
        transform: translateX(4px);
    }

    .quick-start {
        display: flex;
        align-items: center;
        gap: 10px;
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 16px;
        padding: 10px 14px;
        margin-bottom: 24px;
        transition: border-color 0.2s;
    }

    .quick-start:focus-within {
        border-color: rgba(0, 122, 255, 0.35);
    }

    .quick-start-icon {
        font-size: 20px !important;
        color: var(--mud-palette-text-secondary);
        opacity: 0.6;
        flex: 0 0 auto;
    }

    .quick-start-play {
        flex: 0 0 auto;
    }

    .stats-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px;
        margin-bottom: 36px;
    }

    .stat-card {
        background: var(--mud-palette-surface);
        border-radius: 16px;
        padding: 20px 22px;
        border: 1px solid var(--mud-palette-divider);
        transition: transform 0.2s, border-color 0.2s;
    }

    .stat-card:hover {
        transform: translateY(-1px);
        border-color: rgba(0, 122, 255, 0.18);
    }

    .stat-label {
        font-size: 0.75rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--mud-palette-text-secondary);
    }

    .stat-label-row {
        display: flex;
        align-items: center;
        gap: 8px;
        justify-content: space-between;
    }

    .stat-goal-edit {
        background: transparent;
        border: none;
        font-size: 0.6875rem;
        color: var(--mud-palette-text-secondary);
        opacity: 0.5;
        cursor: pointer;
