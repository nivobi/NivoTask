        new("Warm", "linear-gradient(135deg, #fa709a 0%, #fee140 100%)"),
        new("Night", "linear-gradient(135deg, #0c3483 0%, #a2b6df 100%)"),
        new("Mint", "linear-gradient(135deg, #43e97b 0%, #38f9d7 100%)"),
        new("Peach", "linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%)"),
        new("Slate", "linear-gradient(135deg, #868f96 0%, #596164 100%)")
    ];

    private record IconOption(string Name, string Value);

    private static readonly IconOption[] _iconOptions =
    [
        // General
        new("Dashboard", Icons.Material.Filled.Dashboard),
