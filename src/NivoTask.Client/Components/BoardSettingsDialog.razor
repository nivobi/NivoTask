        new("Flag", Icons.Material.Filled.Flag),
        new("Label", Icons.Material.Filled.Label),
        new("Pin", Icons.Material.Filled.PushPin),
        new("Lightbulb", Icons.Material.Filled.Lightbulb),
        new("Bolt", Icons.Material.Filled.Bolt),
        new("Target", Icons.Material.Filled.GpsFixed),
        new("Explore", Icons.Material.Filled.Explore),
        // Work & Dev
        new("Work", Icons.Material.Filled.Work),
        new("Code", Icons.Material.Filled.Code),
        new("Terminal", Icons.Material.Filled.Terminal),
        new("Bug", Icons.Material.Filled.BugReport),
        new("Build", Icons.Material.Filled.Build),
        new("Rocket", Icons.Material.Filled.RocketLaunch),
        new("Api", Icons.Material.Filled.Api),
        new("Database", Icons.Material.Filled.Storage),
        new("Cloud", Icons.Material.Filled.Cloud),
        new("Security", Icons.Material.Filled.Security),
        new("Analytics", Icons.Material.Filled.Analytics),
        new("Settings", Icons.Material.Filled.Settings),
        // Creative
        new("Design", Icons.Material.Filled.DesignServices),
        new("Palette", Icons.Material.Filled.Palette),
        new("Brush", Icons.Material.Filled.Brush),
