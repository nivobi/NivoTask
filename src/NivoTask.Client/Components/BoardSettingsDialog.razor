@using MudBlazor.Utilities
@inject BoardService BoardService
@inject ColumnService ColumnService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager Navigation

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Board Settings</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_boardName" Label="Board Name" Variant="Variant.Outlined"
                      Required="true" RequiredError="Board name is required" Class="mb-4" />
        <MudText Typo="Typo.body2" Style="font-weight: 600; opacity: 0.5; margin-bottom: 8px;">Color</MudText>
        <div class="d-flex flex-wrap align-center gap-2 mb-4">
            @foreach (var color in _colorOptions)
            {
                <div @onclick="() => { _boardColor = color; _customColor = false; }"
                     style="width: 32px; height: 32px; border-radius: 8px; background: @color; cursor: pointer; border: 2px solid @(!_customColor && _boardColor == color ? "var(--mud-palette-text-primary)" : "transparent"); transition: border-color var(--duration-fast) var(--ease-standard);">
                </div>
            }
            <div @onclick="() => _customColor = true"
                 style="width: 32px; height: 32px; border-radius: 8px; cursor: pointer; border: 2px solid @(_customColor ? "var(--mud-palette-text-primary)" : "var(--mud-palette-divider)"); display: flex; align-items: center; justify-content: center; background: @(_customColor && !string.IsNullOrEmpty(_boardColor) ? _boardColor : "conic-gradient(red, yellow, lime, aqua, blue, magenta, red)"); transition: border-color var(--duration-fast) var(--ease-standard);"
                 title="Custom color">
            </div>
        </div>
        @if (_customColor)
        {
            <MudColorPicker @bind-Value="_pickerColor" Style="margin-bottom: 16px;"
                            ColorPickerMode="ColorPickerMode.HEX"
                            DisableAlpha="true"
                            DisableToolbar="false"
                            DisablePreview="false" />
        }

        <MudText Typo="Typo.body2" Style="font-weight: 600; opacity: 0.5; margin-bottom: 8px;">Icon</MudText>
        <div class="d-flex flex-wrap gap-1 mb-4" style="max-height: 180px; overflow-y: auto; padding: 4px;">
            @foreach (var icon in _iconOptions)
            {
                <div @onclick="() => _boardIcon = icon.Value"
                     style="width: 40px; height: 40px; border-radius: 8px; display: flex; align-items: center; justify-content: center; cursor: pointer; background: @(_boardIcon == icon.Value ? "var(--mud-palette-action-default-hover)" : "transparent"); border: 2px solid @(_boardIcon == icon.Value ? "var(--mud-palette-text-primary)" : "transparent"); transition: all var(--duration-fast) var(--ease-standard);"
                     title="@icon.Name">
                    <MudIcon Icon="@icon.Value" Size="Size.Small" Style="opacity: 0.7;" />
                </div>
            }
        </div>

        <MudText Typo="Typo.body2" Style="font-weight: 600; opacity: 0.5; margin-bottom: 8px;">Background</MudText>
        <div class="d-flex flex-wrap gap-2 mb-4">
            <div @onclick="() => { _bgType = null; _bgValue = null; }"
                 style="width: 48px; height: 32px; border-radius: 6px; cursor: pointer; background: var(--mud-palette-background-gray);
                        border: 2px solid @(_bgType is null ? "var(--mud-palette-text-primary)" : "transparent");
                        display: flex; align-items: center; justify-content: center; font-size: 0.625rem; opacity: 0.5;">
                None
            </div>
            @foreach (var grad in _gradientOptions)
            {
                <div @onclick="() => { _bgType = 1; _bgValue = grad.Value; }"
                     style="width: 48px; height: 32px; border-radius: 6px; cursor: pointer; background: @grad.Value;
                            border: 2px solid @(_bgType == 1 && _bgValue == grad.Value ? "var(--mud-palette-text-primary)" : "transparent");"
                     title="@grad.Name">
                </div>
            }
        </div>

        <MudDivider Class="my-4" />

        <MudText Typo="Typo.subtitle1" Class="mb-2">Columns</MudText>

        @foreach (var (col, index) in _columns.Select((c, i) => (c, i)))
        {
            <MudPaper Class="pa-2 mb-2 d-flex align-center" Elevation="0" Outlined="true">
                <MudTextField @bind-Value="col.Name" Variant="Variant.Text" Class="flex-grow-1"
                              Immediate="true" />
                <MudIconButton Icon="@Icons.Material.Filled.ArrowUpward" Size="Size.Small"
                               Disabled="@(index == 0)"
                               OnClick="@(() => MoveColumn(index, -1))" />
                <MudIconButton Icon="@Icons.Material.Filled.ArrowDownward" Size="Size.Small"
                               Disabled="@(index == _columns.Count - 1)"
                               OnClick="@(() => MoveColumn(index, 1))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                               Disabled="@(_columns.Count <= 1)"
                               OnClick="@(() => DeleteColumn(col))" />
            </MudPaper>
        }

        @if (!string.IsNullOrEmpty(_columnError))
        {
            <MudAlert Severity="Severity.Warning" Class="mb-2">@_columnError</MudAlert>
        }

        <MudButton Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                   OnClick="AddColumn" Class="mb-4">
            Add Column
        </MudButton>

        <MudDivider Class="my-4" />

        <MudText Typo="Typo.caption" Color="Color.Error" Class="mb-2">DANGER ZONE</MudText>
        <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="ConfirmDeleteBoard">
            Delete Board
        </MudButton>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   OnClick="SaveChanges" Disabled="@(string.IsNullOrWhiteSpace(_boardName) || _saving)">
            @if (_saving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Save Changes
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public int BoardId { get; set; }
    [Parameter] public string BoardName { get; set; } = string.Empty;
    [Parameter] public string? BoardColor { get; set; }
    [Parameter] public string? BoardIcon { get; set; }
    [Parameter] public List<ColumnEditModel> Columns { get; set; } = [];
    [Parameter] public int? BoardBackgroundType { get; set; }
    [Parameter] public string? BoardBackgroundValue { get; set; }

