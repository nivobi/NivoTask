@using NivoTask.Client.Models

<MudCard Elevation="0" Class="task-card pa-3 mb-2" @onclick="HandleClick">
    <MudCardContent Class="pa-0">
        <MudText Typo="Typo.body2" Style="font-weight: 500; line-height: 1.45;">@Item.Title</MudText>
        @if (Item.SubTaskCount > 0 || Item.TotalTimeSeconds > 0)
        {
            <div class="d-flex align-center gap-3 mt-2">
                @if (Item.SubTaskCount > 0)
                {
                    <div class="d-flex align-center gap-1">
                        <MudIcon Icon="@Icons.Material.Outlined.Checklist" Size="Size.Small"
                                 Style="font-size: 13px; opacity: 0.3;" />
                        <MudText Typo="Typo.body2" Style="opacity: 0.35; font-size: 0.6875rem;">
                            @Item.SubTaskProgress
                        </MudText>
                    </div>
                }
                @if (Item.TotalTimeSeconds > 0)
                {
                    <div class="d-flex align-center gap-1">
                        <MudIcon Icon="@Icons.Material.Outlined.Schedule" Size="Size.Small"
                                 Style="font-size: 13px; opacity: 0.3;" />
                        <MudText Typo="Typo.body2" Style="opacity: 0.35; font-size: 0.6875rem; font-variant-numeric: tabular-nums;">
                            @Item.FormattedTime
                        </MudText>
                    </div>
                }
            </div>
        }
    </MudCardContent>
</MudCard>

@code {
    [Parameter] public BoardTaskItem Item { get; set; } = null!;
    [Parameter] public EventCallback<int> OnTaskClicked { get; set; }

    private async Task HandleClick()
    {
        await OnTaskClicked.InvokeAsync(Item.Id);
    }
}
