@using NivoTask.Client.Models

<div class="task-card" @onclick="HandleClick">
    <span class="task-card-title">@Item.Title</span>
    @if (Item.SubTaskCount > 0 || Item.TotalTimeSeconds > 0)
    {
        <div class="task-card-meta">
            @if (Item.SubTaskCount > 0)
            {
                <div class="task-card-badge">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>
                    </svg>
                    <span>@Item.SubTaskProgress</span>
                </div>
            }
            @if (Item.TotalTimeSeconds > 0)
            {
                <div class="task-card-badge">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                    </svg>
                    <span>@Item.FormattedTime</span>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public BoardTaskItem Item { get; set; } = null!;
    [Parameter] public EventCallback<int> OnTaskClicked { get; set; }

    private async Task HandleClick()
    {
        await OnTaskClicked.InvokeAsync(Item.Id);
    }
}
