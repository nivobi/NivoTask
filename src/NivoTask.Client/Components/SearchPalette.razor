@using NivoTask.Shared.Dtos.Tasks
@inject TaskService TaskService

@if (IsOpen)
{
    <div class="search-palette-overlay" @onclick="HandleClose">
        <div class="search-palette-card" @onclick:stopPropagation="true">
            <div class="search-palette-input">
                <MudIcon Icon="@Icons.Material.Filled.Search" Style="font-size: 18px; opacity: 0.5;" />
                <input type="text" @ref="_inputRef" value="@_query"
                       @oninput="HandleInput" @onkeydown="HandleKeyDown"
                       placeholder="Search tasks across boards..."
                       class="search-palette-text" autofocus />
                <span class="search-palette-hint">Esc to close</span>
            </div>
            @if (_loading)
            {
                <div class="search-palette-loading">
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                </div>
            }
            else if (_results.Count > 0)
            {
                <div class="search-palette-results">
                    @for (int i = 0; i < _results.Count; i++)
                    {
                        var idx = i;
                        var r = _results[idx];
                        <div class="search-palette-row @(idx == _selected ? "selected" : "")"
                             @onclick="() => Select(r)"
                             @onmouseenter="() => _selected = idx">
                            <span class="search-palette-dot" style="@($"background: {r.BoardColor ?? "#888"};")"></span>
                            <div class="search-palette-row-text">
                                <div class="search-palette-row-title @(r.IsDone ? "is-done" : "")">
                                    @r.Title
                                    @if (r.ParentTaskId.HasValue)
                                    {
                                        <span class="search-palette-pill">sub-task</span>
                                    }
                                </div>
                                <div class="search-palette-row-sub">@r.BoardName · @r.ColumnName</div>
                            </div>
                            @if (r.IsDone)
                            {
                                <span class="search-palette-pill done">done</span>
                            }
                        </div>
                    }
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(_query))
            {
                <div class="search-palette-empty">No matches.</div>
            }
            else
            {
                <div class="search-palette-empty">Type to search.</div>
            }
        </div>
    </div>
}

<style>
    .search-palette-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.45);
        z-index: 2000;
        display: flex;
        align-items: flex-start;
        justify-content: center;
        padding-top: 12vh;
        backdrop-filter: blur(4px);
        animation: fadeIn 0.15s ease-out;
    }

    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

    .search-palette-card {
        width: min(560px, calc(100vw - 32px));
        background: var(--mud-palette-surface);
        border-radius: 16px;
        box-shadow: 0 24px 60px rgba(0, 0, 0, 0.45);
        overflow: hidden;
        border: 1px solid var(--mud-palette-divider);
    }

    .search-palette-input {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 14px 18px;
        border-bottom: 1px solid var(--mud-palette-divider);
    }

    .search-palette-text {
        flex: 1;
        background: transparent;
        border: none;
        outline: none;
        font-size: 1rem;
        font-weight: 500;
        color: var(--mud-palette-text-primary);
        font-family: inherit;
    }

    .search-palette-hint {
        font-size: 0.6875rem;
        color: var(--mud-palette-text-secondary);
        opacity: 0.6;
        font-weight: 500;
    }

    .search-palette-loading {
        padding: 24px;
        text-align: center;
    }

    .search-palette-results {
        max-height: 50vh;
        overflow-y: auto;
        padding: 6px 0;
    }

    .search-palette-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 18px;
        cursor: pointer;
        transition: background 0.1s;
    }

    .search-palette-row.selected {
        background: var(--mud-palette-background-gray);
    }

    .search-palette-dot {
        width: 8px; height: 8px; border-radius: 50%; flex: 0 0 auto;
    }

    .search-palette-row-text {
        flex: 1;
        min-width: 0;
    }

    .search-palette-row-title {
        font-size: 0.9375rem;
        font-weight: 500;
        color: var(--mud-palette-text-primary);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .search-palette-row-title.is-done {
        text-decoration: line-through;
        opacity: 0.5;
    }

    .search-palette-row-sub {
        font-size: 0.75rem;
        color: var(--mud-palette-text-secondary);
        margin-top: 2px;
    }

    .search-palette-pill {
        font-size: 0.625rem;
        font-weight: 600;
        padding: 1px 7px;
        border-radius: 980px;
        background: var(--mud-palette-background-gray);
        color: var(--mud-palette-text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .search-palette-pill.done {
        background: rgba(54, 179, 126, 0.15);
        color: #36b37e;
    }

    .search-palette-empty {
        padding: 28px 18px;
        text-align: center;
        font-size: 0.8125rem;
        color: var(--mud-palette-text-secondary);
    }
</style>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<TaskSearchResult> OnPick { get; set; }

    private string _query = "";
    private List<TaskSearchResult> _results = [];
    private bool _loading;
    private int _selected;
    private System.Threading.CancellationTokenSource? _debounce;
    private ElementReference _inputRef;
    private bool _wasOpen;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (IsOpen && !_wasOpen)
        {
            _wasOpen = true;
            try { await _inputRef.FocusAsync(); } catch { }
        }
        else if (!IsOpen && _wasOpen)
        {
            _wasOpen = false;
            _query = "";
            _results = [];
            _selected = 0;
        }
    }

    private async Task HandleInput(ChangeEventArgs e)
    {
        _query = e.Value?.ToString() ?? "";
        _selected = 0;
        _debounce?.Cancel();
        var cts = new System.Threading.CancellationTokenSource();
        _debounce = cts;
        try
        {
            await Task.Delay(200, cts.Token);
            if (cts.IsCancellationRequested) return;
            await RunSearch();
        }
        catch (TaskCanceledException) { }
    }

    private async Task RunSearch()
    {
        var q = _query.Trim();
        if (string.IsNullOrEmpty(q))
        {
            _results = [];
            _loading = false;
            StateHasChanged();
            return;
        }
        _loading = true;
        StateHasChanged();
        try { _results = await TaskService.SearchTasksAsync(q, 20); }
        catch { _results = []; }
        _loading = false;
        StateHasChanged();
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            await HandleClose();
        }
        else if (e.Key == "ArrowDown")
        {
            if (_results.Count > 0)
                _selected = Math.Min(_results.Count - 1, _selected + 1);
        }
        else if (e.Key == "ArrowUp")
        {
            if (_results.Count > 0)
                _selected = Math.Max(0, _selected - 1);
        }
        else if (e.Key == "Enter")
        {
            if (_results.Count > 0 && _selected < _results.Count)
                await Select(_results[_selected]);
        }
    }

    private async Task Select(TaskSearchResult r)
    {
        await OnPick.InvokeAsync(r);
        await HandleClose();
    }

    private async Task HandleClose()
    {
        if (OnClose.HasDelegate) await OnClose.InvokeAsync();
    }
}
