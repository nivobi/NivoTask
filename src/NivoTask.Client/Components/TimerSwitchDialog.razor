<div style="padding: 24px;">
    <MudText Typo="Typo.h6" Class="mb-3">Switch timer?</MudText>
    <MudText Typo="Typo.body2" Style="opacity: 0.6; line-height: 1.6;">
        Currently tracking <span style="font-weight: 600; opacity: 1;">@ActiveTaskTitle</span>
        <span style="font-variant-numeric: tabular-nums;">(@FormattedElapsed)</span>.
        Switch to <span style="font-weight: 600; opacity: 1;">@NewTaskTitle</span>?
    </MudText>
    <div class="d-flex justify-end gap-2 mt-4">
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancel"
                   Style="text-transform: none;">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="Confirm"
                   Style="text-transform: none; box-shadow: none;">Switch</MudButton>
    </div>
</div>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public string ActiveTaskTitle { get; set; } = string.Empty;
    [Parameter] public int ActiveElapsedSeconds { get; set; }
    [Parameter] public string NewTaskTitle { get; set; } = string.Empty;

    private string FormattedElapsed
    {
        get
        {
            var h = ActiveElapsedSeconds / 3600;
            var m = (ActiveElapsedSeconds % 3600) / 60;
            if (h > 0) return $"{h}h {m:D2}m";
            return $"{m}m";
        }
    }

    private void Cancel() => MudDialog.Cancel();
    private void Confirm() => MudDialog.Close(DialogResult.Ok(true));
}
