@implements IDisposable
@inject TimerStateService TimerState
@inject TimeEntryService TimeEntryService
@inject ISnackbar Snackbar

@if (TimerState.IsRunning)
{
    <div @onclick="OnChipClicked" class="timer-chip d-flex align-center gap-2"
         style="cursor: pointer; padding: 6px 16px; border-radius: 20px; background: color-mix(in srgb, var(--mud-palette-secondary) 12%, transparent); margin: 0 8px; user-select: none; box-shadow: 0 1px 4px rgba(0,0,0,0.08); transition: background var(--duration-fast) var(--ease-standard), transform var(--duration-fast) var(--ease-standard);">
        <div style="width: 6px; height: 6px; border-radius: 50%; background: var(--mud-palette-secondary); animation: pulse-dot 2s infinite;"></div>
        <span style="font-size: 0.8125rem; font-weight: 500; color: var(--mud-palette-secondary); white-space: nowrap; max-width: 160px; overflow: hidden; text-overflow: ellipsis;">
            @TruncatedLabel
        </span>
        <span style="font-size: 0.8125rem; font-weight: 600; color: var(--mud-palette-secondary); font-variant-numeric: tabular-nums;">
            @FormattedElapsed
        </span>
        <div @onclick="OnStopClicked" @onclick:stopPropagation="true"
             style="width: 22px; height: 22px; border-radius: 6px; background: color-mix(in srgb, var(--mud-palette-secondary) 15%, transparent); display: flex; align-items: center; justify-content: center; cursor: pointer; margin-left: 2px; transition: background var(--duration-fast) var(--ease-standard);"
>
            <svg width="10" height="10" viewBox="0 0 24 24" fill="var(--mud-palette-secondary)">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
            </svg>
        </div>
    </div>
}

<style>
    @@keyframes pulse-dot {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.35; transform: scale(0.85); }
    }
</style>

@code {
    [Parameter] public EventCallback<int> OnNavigateToTask { get; set; }
    [Parameter] public EventCallback<int?> OnTimerStopped { get; set; }
    [Parameter] public EventCallback<NivoTask.Shared.Dtos.TimeEntries.TimeEntryResponse?> OnTimerStoppedEntry { get; set; }

    private string DisplayLabel
    {
        get
        {
            // Prefer task title; fall back to notes (free entry tag); finally board name.
            if (!string.IsNullOrWhiteSpace(TimerState.ActiveTaskTitle)) return TimerState.ActiveTaskTitle!;
            if (!string.IsNullOrWhiteSpace(TimerState.ActiveBoardName)) return TimerState.ActiveBoardName!;
            return "Tracking";
        }
    }

    private string TruncatedLabel => DisplayLabel.Length > 24
        ? DisplayLabel[..21] + "..."
        : DisplayLabel;

    private string FormattedElapsed
    {
        get
        {
            var s = TimerState.ElapsedSeconds;
            var h = s / 3600;
            var m = (s % 3600) / 60;
            var sec = s % 60;
            return h > 0 ? $"{h}:{m:D2}:{sec:D2}" : $"{m}:{sec:D2}";
        }
    }

    protected override void OnInitialized()
        => TimerState.OnTimerChanged += HandleTimerChanged;

    private async void HandleTimerChanged()
        => await InvokeAsync(StateHasChanged);

    private async Task OnChipClicked()
    {
        if (TimerState.ActiveTaskId.HasValue)
            await OnNavigateToTask.InvokeAsync(TimerState.ActiveTaskId.Value);
    }

    private async Task OnStopClicked()
    {
        var taskId = TimerState.ActiveTaskId;
        var boardId = TimerState.ActiveBoardId;
        TimerState.Clear();
        try
        {
            NivoTask.Shared.Dtos.TimeEntries.TimeEntryResponse? stoppedEntry = null;
            if (taskId.HasValue)
                stoppedEntry = await TimeEntryService.StopTimerAsync(taskId.Value);
            else if (boardId.HasValue)
                stoppedEntry = await TimeEntryService.StopBoardTimerAsync(boardId.Value);
            await OnTimerStopped.InvokeAsync(taskId);
            await OnTimerStoppedEntry.InvokeAsync(stoppedEntry);
        }
        catch
        {
            try
            {
                var active = await TimeEntryService.GetActiveTimerAsync();
                if (active is not null)
                    TimerState.SetActive(active.TaskId, active.TaskTitle, active.BoardId, active.BoardName, active.EntryId, active.StartTime);
            }
            catch { }
            Snackbar.Add("Could not stop timer.", Severity.Error);
        }
    }

    public void Dispose()
        => TimerState.OnTimerChanged -= HandleTimerChanged;
}
