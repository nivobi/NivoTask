@using NivoTask.Shared.Dtos.TimeEntries
@implements IDisposable
@inject TimerStateService TimerState
@inject TimeEntryService TimeEntryService
@inject TaskService TaskService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<div class="subtask-row @(IsActiveTimer ? "active-timer" : "") @(_isDone ? "is-done" : "")" @onmouseenter="() => _hovered = true" @onmouseleave="() => _hovered = false">
    <div class="d-flex align-center" style="min-height: 40px; padding: 4px 8px; gap: 6px;">
        <div class="done-check @(_isDone ? "checked" : "")" @onclick="ToggleDone"
             style="width: 18px; height: 18px; border-radius: 4px; border: 2px solid @(_isDone ? "#36b37e" : "var(--mud-palette-action-disabled)"); flex-shrink: 0; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 0.15s ease; background: @(_isDone ? "#36b37e" : "transparent");">
            @if (_isDone)
            {
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"/>
                </svg>
            }
        </div>
        <MudIconButton Icon="@TimerIcon" Size="Size.Medium"
                       Color="@(IsActiveTimer ? Color.Secondary : Color.Default)"
                       OnClick="HandleTimerToggle"
                       Style="@(IsActiveTimer ? "" : "opacity: 0.6;")" />
        @if (_editing)
        {
            <MudTextField T="string" @bind-Value="_editTitle" Variant="Variant.Text"
                          Class="flex-grow-1" Immediate="true"
                          OnKeyDown="HandleEditKeyDown" OnBlur="SaveEdit"
                          AutoFocus="true" Style="font-size: 0.875rem;" />
        }
        else
        {
            <MudText Typo="Typo.body2" Class="flex-grow-1 mud-text-truncate"
                     @onclick="StartEditing"
                     Style="@($"cursor: text; font-size: 0.875rem; line-height: 1.5;{(_isDone ? " text-decoration: line-through; opacity: 0.4;" : "")}")">
                @SubTask.Title
            </MudText>
        }
        @if (_totalSeconds > 0 || IsActiveTimer)
        {
            <MudText Typo="Typo.body2" Style="opacity: 0.35; white-space: nowrap; font-size: 0.75rem; font-variant-numeric: tabular-nums;">
                @FormattedTime
            </MudText>
        }
        @if (_hovered)
        {
            <MudIconButton Icon="@Icons.Material.Outlined.DeleteOutline" Size="Size.Small"
                           Color="Color.Default" OnClick="HandleDelete"
                           Style="opacity: 0.3; font-size: 16px;" />
        }
        <MudIconButton Icon="@(_expanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                       Size="Size.Small" Color="Color.Default"
                       OnClick="ToggleExpand"
                       Style="opacity: 0.25;" />
    </div>

    @if (_expanded)
    {
        <div style="padding: 4px 8px 12px 44px;">
            @if (_loadingEntries)
            {
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100%" Height="20px"
                             Style="border-radius: 4px;" />
            }
            else if (_entries is not null)
            {
                @if (_entries.Count == 0 && !_showAddForm)
                {
                    <MudText Typo="Typo.body2" Style="opacity: 0.3; font-size: 0.75rem;">
                        No entries yet
                    </MudText>
                }
                else
                {
                    <div style="display: flex; flex-direction: column; gap: 2px; margin-bottom: 6px;">
                        @foreach (var entry in _entries)
                        {
                            <div class="entry-row d-flex align-center" style="gap: 8px; padding: 3px 0; border-radius: 4px;" @onmouseenter="() => _hoveredEntryId = entry.Id" @onmouseleave="() => _hoveredEntryId = 0">
                                <MudIcon Icon="@(entry.IsManual ? Icons.Material.Outlined.EditNote : Icons.Material.Outlined.Timer)"
                                         Size="Size.Small" Style="opacity: 0.2; font-size: 14px; flex-shrink: 0;" />
                                <MudText Typo="Typo.body2" Style="font-size: 0.75rem; font-variant-numeric: tabular-nums; min-width: 44px;">
                                    @FormatDuration(entry.DurationSeconds)
                                </MudText>
                                <MudText Typo="Typo.body2" Style="opacity: 0.3; font-size: 0.6875rem; min-width: 44px;">
                                    @FormatEntryDate(entry)
                                </MudText>
                                @if (!string.IsNullOrEmpty(entry.Notes))
                                {
                                    <MudText Typo="Typo.body2" Class="flex-grow-1 mud-text-truncate"
                                             Style="opacity: 0.4; font-size: 0.75rem;">
                                        @entry.Notes
                                    </MudText>
                                }
                                else
                                {
                                    <div class="flex-grow-1"></div>
                                }
                                @if (_hoveredEntryId == entry.Id)
                                {
                                    <MudIconButton Icon="@Icons.Material.Outlined.Close" Size="Size.Small"
                                                   OnClick="() => DeleteEntry(entry)"
                                                   Style="opacity: 0.3; font-size: 14px;" />
                                }
                            </div>
                        }
                    </div>
                }

                @if (_showAddForm)
                {
                    <div class="d-flex align-center gap-2 mt-1" style="padding: 4px 0;">
                        <MudNumericField T="int" @bind-Value="_manualDuration" Label="Min"
                                      Variant="Variant.Outlined" Style="max-width: 72px; font-size: 0.8125rem;"
                                      Min="1" Max="1440" />
                        <MudTextField T="string" @bind-Value="_manualNotes" Placeholder="Notes..."
                                      Variant="Variant.Outlined" Class="flex-grow-1"
                                      Style="font-size: 0.8125rem;" />
                        <MudIconButton Icon="@Icons.Material.Filled.Check" Size="Size.Small"
                                       Color="Color.Secondary" OnClick="AddManualEntry"
                                       Disabled="_saving" />
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                       OnClick="() => _showAddForm = false"
                                       Style="opacity: 0.4;" />
                    </div>
                }
                else
                {
                    <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Add" OnClick="() => _showAddForm = true"
                               Style="text-transform: none; font-size: 0.75rem; opacity: 0.4; padding: 2px 8px; margin-top: 2px;">
                        Add entry
                    </MudButton>
                }
            }
        </div>
    }
</div>

@code {
    [Parameter] public TaskResponse SubTask { get; set; } = null!;
    [Parameter] public EventCallback OnTimerAction { get; set; }
    [Parameter] public EventCallback<int> OnDeleted { get; set; }

    private bool IsActiveTimer => TimerState.ActiveTaskId == SubTask.Id;
    private string TimerIcon => IsActiveTimer ? Icons.Material.Filled.Pause : Icons.Material.Filled.PlayArrow;

    private string FormattedTime
    {
        get
        {
            var secs = IsActiveTimer ? TimerState.ElapsedSeconds + _totalSeconds : _totalSeconds;
            var h = secs / 3600;
            var m = (secs % 3600) / 60;
            var s = secs % 60;
            if (IsActiveTimer)
                return h > 0 ? $"{h}h {m:D2}m {s:D2}s" : $"{m}m {s:D2}s";
            if (secs < 60) return $"{secs}s";
            if (h > 0) return $"{h}h {m:D2}m";
            return $"{m}m";
        }
    }

    private bool _isDone;
    private bool _expanded;
    private bool _hovered;
    private int _hoveredEntryId;
    private List<TimeEntryResponse>? _entries;
    private bool _loadingEntries;
    private bool _editing;
    private string _editTitle = "";
    private bool _showAddForm;
    private int _manualDuration;
    private string? _manualNotes;
    private bool _saving;
    private int _totalSeconds;

    protected override void OnInitialized()
    {
        _isDone = SubTask.IsDone;
        TimerState.OnTimerChanged += HandleTimerChanged;
    }

    private async void HandleTimerChanged()
        => await InvokeAsync(StateHasChanged);

    public void Dispose()
        => TimerState.OnTimerChanged -= HandleTimerChanged;

    private async Task ToggleDone()
    {
        _isDone = !_isDone;
        SubTask.IsDone = _isDone;
        StateHasChanged();
        try
        {
            await TaskService.ToggleDoneAsync(SubTask.Id);
        }
        catch
        {
            _isDone = !_isDone;
            SubTask.IsDone = _isDone;
            Snackbar.Add("Could not update status.", Severity.Error);
        }
    }

    private async Task HandleTimerToggle()
    {
        if (IsActiveTimer)
        {
            TimerState.Clear();
            try
            {
                await TimeEntryService.StopTimerAsync(SubTask.Id);
                await LoadEntries();
                await OnTimerAction.InvokeAsync();
            }
            catch
            {
                try
                {
                    var active = await TimeEntryService.GetActiveTimerAsync();
                    if (active is not null)
                        TimerState.SetActive(active.TaskId, active.TaskTitle, active.BoardId, active.BoardName, active.EntryId, active.StartTime);
                }
                catch { }
                Snackbar.Add("Could not stop timer.", Severity.Error);
            }
        }
        else
        {
            var response = await TimeEntryService.StartTimerAsync(SubTask.Id);
            if (response.StatusCode == System.Net.HttpStatusCode.Conflict)
            {
                // Get the ACTUAL active timer from the server (not from 409 body which may fail to deserialize)
                var currentActive = await TimeEntryService.GetActiveTimerAsync();
                if (currentActive is null)
                {
                    // No active timer found — stale state, just retry start
                    TimerState.Clear();
                    var retry = await TimeEntryService.StartTimerAsync(SubTask.Id);
                    if (retry.IsSuccessStatusCode)
                    {
                        var started = await TimeEntryService.GetActiveTimerAsync();
                        if (started is not null)
                            TimerState.SetActive(started.TaskId, started.TaskTitle, started.BoardId, started.BoardName, started.EntryId, started.StartTime);
                    }
                    return;
                }

                var parameters = new DialogParameters<TimerSwitchDialog>
                {
                    { x => x.ActiveTaskTitle, currentActive.TaskTitle ?? currentActive.BoardName },
                    { x => x.ActiveElapsedSeconds, currentActive.ElapsedSeconds },
                    { x => x.NewTaskTitle, SubTask.Title }
                };
                var dialog = await DialogService.ShowAsync<TimerSwitchDialog>(
                    "Switch Timer?", parameters, new DialogOptions
                    {
                        MaxWidth = MaxWidth.ExtraSmall,
                        NoHeader = true,
                        BackdropClick = true,
                    });
                var result = await dialog.Result;
                if (result is not null && !result.Canceled)
                {
                    try
                    {
                        if (currentActive.TaskId.HasValue)
                            await TimeEntryService.StopTimerAsync(currentActive.TaskId.Value);
                        else
                            await TimeEntryService.StopBoardTimerAsync(currentActive.BoardId);
                        var startResponse = await TimeEntryService.StartTimerAsync(SubTask.Id);
                        startResponse.EnsureSuccessStatusCode();
                        var newTimer = await TimeEntryService.GetActiveTimerAsync();
                        if (newTimer is not null)
                            TimerState.SetActive(newTimer.TaskId, newTimer.TaskTitle, newTimer.BoardId, newTimer.BoardName, newTimer.EntryId, newTimer.StartTime);
                        await OnTimerAction.InvokeAsync();
                    }
                    catch
                    {
                        Snackbar.Add("Could not switch timer.", Severity.Error);
                        // Refresh timer state from server
                        try
                        {
                            var fresh = await TimeEntryService.GetActiveTimerAsync();
                            if (fresh is not null)
                                TimerState.SetActive(fresh.TaskId, fresh.TaskTitle, fresh.BoardId, fresh.BoardName, fresh.EntryId, fresh.StartTime);
                            else
                                TimerState.Clear();
                        }
                        catch { }
                    }
                }
            }
            else if (response.IsSuccessStatusCode)
            {
                var active = await TimeEntryService.GetActiveTimerAsync();
                if (active is not null)
                    TimerState.SetActive(active.TaskId, active.TaskTitle, active.BoardId, active.BoardName, active.EntryId, active.StartTime);
            }
            else
            {
                Snackbar.Add("Could not start timer.", Severity.Error);
            }
        }
    }

    private async Task ToggleExpand()
    {
        _expanded = !_expanded;
        if (_expanded && _entries is null)
            await LoadEntries();
    }

    private async Task LoadEntries()
    {
        _loadingEntries = true;
        try
        {
            _entries = await TimeEntryService.GetTimeEntriesAsync(SubTask.Id);
            _totalSeconds = _entries.Where(e => !e.IsRunning).Sum(e => e.DurationSeconds);
        }
        catch
        {
            _entries = [];
            Snackbar.Add("Could not load time entries.", Severity.Error);
        }
        _loadingEntries = false;
    }

    private void StartEditing()
    {
        _editTitle = SubTask.Title;
        _editing = true;
    }

    private async Task SaveEdit()
    {
        _editing = false;
        if (string.IsNullOrWhiteSpace(_editTitle) || _editTitle == SubTask.Title) return;
        var oldTitle = SubTask.Title;
        SubTask.Title = _editTitle;
        try
        {
            await TaskService.UpdateTaskAsync(SubTask.Id, new UpdateTaskRequest { Title = _editTitle, Description = SubTask.Description });
        }
        catch
        {
            SubTask.Title = oldTitle;
            Snackbar.Add("Could not update sub-task.", Severity.Error);
        }
    }

    private async Task HandleEditKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SaveEdit();
        else if (e.Key == "Escape") { _editing = false; }
    }

    private async Task AddManualEntry()
    {
        if (_manualDuration < 1 || _manualDuration > 1440) return;
        _saving = true;
        try
        {
            var entry = await TimeEntryService.CreateManualEntryAsync(SubTask.Id,
                new CreateTimeEntryRequest { DurationMinutes = _manualDuration, Notes = _manualNotes });
            if (entry is not null)
            {
                _entries ??= [];
                _entries.Insert(0, entry);
                _totalSeconds += entry.DurationSeconds;
            }
            _manualDuration = 0;
            _manualNotes = null;
            _showAddForm = false;
            await OnTimerAction.InvokeAsync();
        }
        catch
        {
            Snackbar.Add("Could not add time entry.", Severity.Error);
        }
        _saving = false;
    }

    private async Task HandleDelete()
    {
        if (IsActiveTimer)
        {
            try { await TimeEntryService.StopTimerAsync(SubTask.Id); TimerState.Clear(); }
            catch { }
        }
        await OnDeleted.InvokeAsync(SubTask.Id);
    }

    private async Task DeleteEntry(TimeEntryResponse entry)
    {
        _entries?.Remove(entry);
        _totalSeconds -= entry.DurationSeconds;
        StateHasChanged();
        try
        {
            await TimeEntryService.DeleteTimeEntryAsync(entry.Id);
            await OnTimerAction.InvokeAsync();
            Snackbar.Add("Entry deleted", Severity.Normal);
        }
        catch
        {
            _entries?.Insert(0, entry);
            _totalSeconds += entry.DurationSeconds;
            Snackbar.Add("Could not delete entry.", Severity.Error);
        }
    }

    private static string FormatDuration(int seconds)
    {
        var h = seconds / 3600;
        var m = (seconds % 3600) / 60;
        var s = seconds % 60;
        if (h > 0) return $"{h}h {m:D2}m {s:D2}s";
        if (m > 0) return $"{m}m {s:D2}s";
        return $"{s}s";
    }

    private static string FormatEntryDate(TimeEntryResponse entry)
        => (entry.StartTime ?? entry.EndTime ?? DateTime.UtcNow).ToString("MMM d");
}
